<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Task_Flyout.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Task Flyout">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid>
        <NavigationView x:Name="MainNav" PaneDisplayMode="Left" IsSettingsVisible="True"
                        ItemInvoked="MainNav_ItemInvoked" BackRequested="MainNav_BackRequested">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="MainWindow_NavCalendar" Content="主日历视图" Tag="Calendar">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE787;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Uid="MainWindow_NavWeather" Content="天气" Tag="Weather">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xECAA;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator Margin="16,8,16,8"/>

                <StackPanel x:Name="FooterContentPanel" Padding="16,0,24,16" Spacing="12">

                    <ItemsRepeater x:Name="AccountListRepeater">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="4"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>

                                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                          Background="Transparent" BorderThickness="0" Padding="0" IsExpanded="True">

                                    <Expander.Header>
                                        <Grid HorizontalAlignment="Stretch" Margin="0,0,8,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0" Glyph="&#xE77B;" FontSize="15" Margin="0,0,12,0" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="1" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"
                                                       Text="{Binding ProviderName}" TextTrimming="CharacterEllipsis"/>

                                            <Button Grid.Column="2" Padding="4" Background="Transparent" BorderThickness="0"
                                                    Tag="{Binding ProviderName}" Click="BtnRemoveAccount_Click" ToolTipService.ToolTip="移除账户" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                            </Button>
                                        </Grid>
                                    </Expander.Header>

                                    <Expander.Content>
                                        <StackPanel Spacing="0" Margin="0,4,0,0">

                                            <ItemsRepeater ItemsSource="{Binding Calendars}">
                                                <ItemsRepeater.Layout>
                                                    <StackLayout Spacing="0"/>
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="32,0,0,8" ColumnSpacing="8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Width="16" Height="16" CornerRadius="8"
                                                                VerticalAlignment="Center" Tag="{Binding}"
                                                                Loaded="CalendarColorDot_Loaded"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                            <ToggleSwitch Grid.Column="2" IsOn="{Binding IsVisible, Mode=TwoWay}"
                                                                          OffContent="" OnContent="" MinWidth="0" Margin="0"
                                                                          Toggled="CalendarToggle_Toggled" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>

                                            <Grid Margin="32,0,0,8" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="16" Height="16" CornerRadius="8"
                                                    VerticalAlignment="Center" Tag="{Binding}"
                                                    Loaded="TaskColorDot_Loaded"/>
                                                <TextBlock x:Uid="MainWindow_ToggleTasks" Grid.Column="1" Text="待办任务" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <ToggleSwitch Grid.Column="2" IsOn="{Binding ShowTasks, Mode=TwoWay}"
                                                              OffContent="" OnContent="" MinWidth="0" Margin="0"
                                                              Toggled="AccountToggle_Toggled" Tag="{Binding ProviderName}" VerticalAlignment="Center"/>
                                            </Grid>

                                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8,0,8"/>
                                        </StackPanel>
                                    </Expander.Content>
                                </Expander>

                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                    <Button x:Name="BtnAddAccount" HorizontalAlignment="Stretch" Click="BtnAddAccount_Click" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                            <TextBlock x:Uid="MainWindow_BtnAddAccount" Text="添加账户"/>
                        </StackPanel>
                    </Button>

                    <Button x:Uid="MainWindow_BtnForceSync" Content="强制立即同步" HorizontalAlignment="Stretch" Click="BtnForceSync_Click"/>
                </StackPanel>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>
