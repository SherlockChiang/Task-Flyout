<Window
    x:Class="Task_Flyout.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Task Flyout">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid>
        <NavigationView x:Name="MainNav" PaneDisplayMode="Left" IsSettingsVisible="True" ItemInvoked="MainNav_ItemInvoked">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="MainWindow_NavCalendar" Content="主日历视图" Tag="Calendar">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE787;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                        <StackPanel x:Name="FooterContentPanel" Padding="16,0,16,16" Spacing="12">

                            <ItemsRepeater x:Name="AccountListRepeater">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="8"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="0">
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="&#xE77B;" FontSize="16" Margin="0,0,12,0" Foreground="{ThemeResource SystemAccentColor}"/>

                                                <TextBlock Grid.Column="1" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"
                                                           Text="{Binding ProviderName}" TextTrimming="CharacterEllipsis"/>

                                                <Button Grid.Column="2" Padding="4" Background="Transparent" BorderThickness="0"
                                                        Tag="{Binding ProviderName}" Click="BtnRemoveAccount_Click" ToolTipService.ToolTip="移除账户">
                                                    <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                                </Button>
                                            </Grid>

                                            <ItemsRepeater ItemsSource="{Binding Calendars}">
                                                <ItemsRepeater.Layout>
                                                    <StackLayout Spacing="0"/>
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="28,0,0,4" ColumnSpacing="12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" 
                                                                       TextTrimming="CharacterEllipsis" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                            <ToggleSwitch Grid.Column="1" IsOn="{Binding IsVisible, Mode=TwoWay}" 
                                                                          OffContent="" OnContent="" MinWidth="0" Margin="0" 
                                                                          Toggled="CalendarToggle_Toggled" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>

                                            <Grid Margin="28,0,0,4" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Uid="MainWindow_ToggleTasks" Grid.Column="0" Text="待办任务" VerticalAlignment="Center" 
                                                           TextTrimming="CharacterEllipsis" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <ToggleSwitch Grid.Column="1" IsOn="{Binding ShowTasks, Mode=TwoWay}" 
                                                              OffContent="" OnContent="" MinWidth="0" Margin="0" 
                                                              Toggled="AccountToggle_Toggled" Tag="{Binding ProviderName}" VerticalAlignment="Center"/>
                                            </Grid>

                                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,12,0,16"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                            <Button x:Name="BtnAddAccount" HorizontalAlignment="Stretch" Click="BtnAddAccount_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                                    <TextBlock x:Uid="MainWindow_BtnAddAccount" Text="添加账户"/>
                                </StackPanel>
                            </Button>

                            <Button x:Uid="MainWindow_BtnForceSync" Content="强制立即同步" HorizontalAlignment="Stretch" Click="BtnForceSync_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>