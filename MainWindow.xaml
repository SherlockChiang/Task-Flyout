<Window
    x:Class="Task_Flyout.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Task Flyout">

    <Grid Padding="20" ColumnSpacing="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Spacing="10">
            <TextBlock Text="我的日历" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
            <CalendarView x:Name="MainCalendar" 
                          CalendarViewDayItemChanging="MainCalendar_CalendarViewDayItemChanging"
                          SelectedDatesChanged="MainCalendar_SelectedDatesChanged"
                          Width="300" Height="350"/>
            <ProgressRing x:Name="LoadingRing" IsActive="False" Visibility="Collapsed" HorizontalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Column="1" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="10">
                <TextBlock x:Name="SelectedDateText" Text="选中日期的日程" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                <ListView x:Name="EventsListView" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Height="200">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,5">
                                <TextBlock Text="{Binding Summary}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DisplayTime}" FontSize="12" Foreground="Gray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <StackPanel Grid.Row="1" Spacing="10">
                <TextBlock Text="我的任务 (Google Tasks)" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="Bold"/>
                <ListView x:Name="TasksListView" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Height="200">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Title}" IsChecked="{Binding IsCompleted}" 
                                      Checked="TaskCheckBox_Checked" Unchecked="TaskCheckBox_Unchecked"
                                      Tag="{Binding Id}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Grid>
    </Grid>
</Window>