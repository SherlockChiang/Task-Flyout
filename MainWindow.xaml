<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Task_Flyout.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Task_Flyout.Views"
    Title="Task Flyout">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <views:ProviderToBrushConverter x:Key="ColorHexToBrushConverter"/>
        </Grid.Resources>
        <NavigationView x:Name="MainNav" PaneDisplayMode="Left" IsSettingsVisible="True"
                        ItemInvoked="MainNav_ItemInvoked" BackRequested="MainNav_BackRequested">

            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="MainWindow_NavCalendar" Content="主日历视图" Tag="Calendar">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE263;" FontFamily="ms-appx:///Assets/FluentSystemIcons-Filled.ttf#FluentSystemIcons-Filled"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="TasksNavItem" Content="任务" Tag="Tasks">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE73E;" FontFamily="Segoe MDL2 Assets"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Uid="MainWindow_NavWeather" x:Name="WeatherNavItem" Content="天气" Tag="Weather">
                    <NavigationViewItem.Icon>
                        <FontIcon x:Name="WeatherNavIcon" Glyph="&#xF8BA;" FontFamily="ms-appx:///Assets/FluentSystemIcons-Filled.ttf#FluentSystemIcons-Filled"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="MailNavItem" Content="邮件" Tag="Mail">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE715;" FontFamily="Segoe MDL2 Assets"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="RssNavItem" Content="RSS" Tag="Rss">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE789;" FontFamily="Segoe MDL2 Assets"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>
