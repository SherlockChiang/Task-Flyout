<Window
    x:Class="Task_Flyout.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Task Flyout">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid>
        <NavigationView x:Name="MainNav" PaneDisplayMode="Left" IsSettingsVisible="True" ItemInvoked="MainNav_ItemInvoked">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="MainWindow_NavCalendar" Content="主日历视图" Tag="Calendar">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE787;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneFooter>
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                        <StackPanel x:Name="FooterContentPanel" Padding="16,0,16,16" Spacing="12">

                            <!-- Dynamic account list -->
                            <ItemsRepeater x:Name="AccountListRepeater">
                                <ItemsRepeater.Layout>
                                    <StackLayout Spacing="16"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Spacing="6">
                                            <!-- Account header -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="&#xE77B;" FontSize="14" Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="1" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"
                                                           Text="{Binding ProviderName}"/>
                                                <Button Grid.Column="2" Padding="4" Background="Transparent" BorderThickness="0"
                                                        Tag="{Binding ProviderName}" Click="BtnRemoveAccount_Click">
                                                    <FontIcon Glyph="&#xE711;" FontSize="11"/>
                                                </Button>
                                            </Grid>

                                            <!-- Event/Task toggles -->
                                            <ToggleSwitch Header="显示日程" IsOn="{Binding ShowEvents, Mode=TwoWay}" MinWidth="0"
                                                          Toggled="AccountToggle_Toggled" Tag="{Binding ProviderName}"/>
                                            <ToggleSwitch Header="显示任务" IsOn="{Binding ShowTasks, Mode=TwoWay}" MinWidth="0"
                                                          Toggled="AccountToggle_Toggled" Tag="{Binding ProviderName}"/>

                                            <!-- Subscribed calendars -->
                                            <ItemsRepeater ItemsSource="{Binding Calendars}">
                                                <ItemsRepeater.Layout>
                                                    <StackLayout Spacing="2"/>
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate>
                                                        <ToggleSwitch IsOn="{Binding IsVisible, Mode=TwoWay}" MinWidth="0"
                                                                      Header="{Binding Name}"
                                                                      Toggled="CalendarToggle_Toggled"/>
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>

                                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>

                            <!-- Add Account button -->
                            <Button x:Name="BtnAddAccount" HorizontalAlignment="Stretch" Click="BtnAddAccount_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                                    <TextBlock x:Uid="MainWindow_BtnAddAccount" Text="添加账户"/>
                                </StackPanel>
                            </Button>

                            <!-- Force Sync button -->
                            <Button x:Uid="MainWindow_BtnForceSync" Content="强制立即同步" HorizontalAlignment="Stretch" Click="BtnForceSync_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>
