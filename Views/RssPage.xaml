<Page
    x:Class="Task_Flyout.Views.RssPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:Task_Flyout.Services"
    Background="Transparent">

    <Grid x:Name="LayoutRoot" Padding="28" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2">
                <TextBlock x:Uid="RssPage_Title" Text="RSS" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock x:Name="SubtitleText"
                           x:Uid="RssPage_AllSubscriptions"
                           Text="全部订阅文章"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <ProgressRing x:Name="LoadingRing"
                          Grid.Column="1"
                          Width="24"
                          Height="24"
                          IsActive="False"
                          Visibility="Collapsed"
                          VerticalAlignment="Center"/>
        </Grid>

        <Grid x:Name="RssContentGrid" Grid.Row="1" ColumnSpacing="12" MinHeight="0" SizeChanged="RssContentGrid_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid x:Name="SubscriptionPane" Grid.Column="0" RowSpacing="10" MinHeight="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="190"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8"
                        Grid.RowSpan="3">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <TextBlock x:Uid="RssPage_FeedLabel" Text="订阅" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button x:Uid="RssPage_BtnAddFolder"
                                    x:Name="AddFolderButton"
                                    HorizontalAlignment="Right"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="AddFolderButton_Click">
                                <FontIcon Glyph="&#xE710;" FontSize="13"/>
                            </Button>
                        </Grid>
                        <TreeView Grid.Row="1"
                                  x:Name="RssTree"
                                  SelectionMode="Single"
                                  CanDragItems="True"
                                  CanReorderItems="True"
                                  AllowDrop="True"
                                  RightTapped="RssTree_RightTapped"
                                  ItemInvoked="RssTree_ItemInvoked"
                                  DragItemsCompleted="RssTree_DragItemsCompleted">
                            <TreeView.ContextFlyout>
                                <MenuFlyout Opening="RssTreeMenu_Opening">
                                    <MenuFlyoutItem x:Name="RenameRssTreeItem" x:Uid="RssPage_Rename" Text="重命名" Click="RenameRssTreeItem_Click"/>
                                    <MenuFlyoutItem x:Name="DeleteRssTreeItem" x:Uid="RssPage_Delete" Text="删除" Click="DeleteRssTreeItem_Click"/>
                                </MenuFlyout>
                            </TreeView.ContextFlyout>
                        </TreeView>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="3"
                           x:Name="SubscriptionStatusText"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <Grid Grid.Row="4" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Uid="RssPage_AddSubscriptionButton" x:Name="AddSubscriptionButton" HorizontalAlignment="Stretch" Click="AddSubscriptionButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                            <TextBlock x:Uid="RssPage_AddFeed" Text="添加订阅"/>
                        </StackPanel>
                    </Button>
                    <Button x:Uid="RssPage_OpmlButton" Grid.Column="1" Width="40" Height="40" Padding="0" AutomationProperties.Name="Import or export subscriptions">
                        <FontIcon Glyph="&#xE712;" FontSize="14"/>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem x:Uid="RssPage_ImportOpml" Text="Import OPML..." Click="ImportOpml_Click">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8B5;"/></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem x:Uid="RssPage_ExportOpml" Text="Export OPML..." Click="ExportOpml_Click">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE898;"/></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
            </Grid>

            <Border x:Name="ArticlePane" Grid.Column="1"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid x:Name="ArticleListHeader" ColumnSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="ArticleTitleColumn" Width="*"/>
                            <ColumnDefinition x:Name="SubscriptionButtonColumn" Width="Auto"/>
                            <ColumnDefinition x:Name="ArticleFilterColumn" Width="Auto"/>
                            <ColumnDefinition x:Name="ArticleSearchColumn" Width="200"/>
                            <ColumnDefinition x:Name="ArticleRefreshColumn" Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel x:Name="ArticleHeaderTitle">
                            <TextBlock x:Name="ArticleListTitle" x:Uid="RssPage_AllArticles" Text="全部文章" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ArticleListSubtitle" x:Uid="RssPage_ArticleStatus" Text="向下滚动加载更多" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" AutomationProperties.LiveSetting="Polite"/>
                        </StackPanel>
                        <Button x:Uid="RssPage_ShowSubscriptions" x:Name="ShowSubscriptionsButton" Grid.Column="1" Visibility="Collapsed"
                                Content="Subscriptions" Click="ShowSubscriptionsButton_Click"/>
                        <ComboBox x:Uid="RssPage_ArticleFilter"
                                  x:Name="ArticleFilterBox"
                                  Grid.Column="2"
                                  MinWidth="112"
                                  SelectedIndex="0"
                                  SelectionChanged="ArticleFilterBox_SelectionChanged"
                                  AutomationProperties.Name="Article filter">
                            <ComboBoxItem x:Uid="RssPage_FilterAll" Content="All" Tag="All"/>
                            <ComboBoxItem x:Uid="RssPage_FilterUnread" Content="Unread" Tag="Unread"/>
                            <ComboBoxItem x:Uid="RssPage_FilterStarred" Content="Starred" Tag="Starred"/>
                        </ComboBox>
                        <AutoSuggestBox x:Uid="RssPage_Search"
                                        x:Name="ArticleSearchBox"
                                        Grid.Column="3"
                                        PlaceholderText="Search cached articles"
                                        TextChanged="ArticleSearchBox_TextChanged"
                                        AutomationProperties.Name="Search cached articles"/>
                        <Button x:Uid="RssPage_RefreshButton" x:Name="RefreshButton" Grid.Column="4" Click="RefreshButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                                <TextBlock x:Uid="MailPage_Refresh" Text="刷新"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ListView Grid.Row="1"
                               x:Name="ArticleList"
                               ItemsSource="{x:Bind Articles}"
                               SelectionMode="None"
                               IsItemClickEnabled="True"
                               ItemClick="ArticleList_ItemClick"
                               ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="services:RssArticle">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                         Padding="14"
                                         Margin="0,0,0,10">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="112"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="112"
                                                Height="76"
                                                CornerRadius="6"
                                                Background="{ThemeResource LayerFillColorAltBrush}"
                                                Visibility="{x:Bind HasImage}">
                                            <Image Source="{x:Bind ImageSource}"
                                                   Stretch="UniformToFill"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="6" Opacity="{x:Bind ReadOpacity}">
                                            <TextBlock Text="{x:Bind Title}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Bind FeedTitle}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock Text="·" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                                <TextBlock Text="{x:Bind PublishedText}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                             <TextBlock Text="{x:Bind Summary}"
                                                       FontSize="13"
                                                       MaxLines="3"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap"
                                                       Visibility="{x:Bind HasSummary}"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                                <Button Width="32"
                                                        Height="28"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        DataContext="{x:Bind}"
                                                        Click="ToggleArticleRead_Click"
                                                        x:Uid="RssPage_ToggleRead"
                                                        AutomationProperties.Name="Toggle read status">
                                                    <FontIcon Glyph="{x:Bind ReadGlyph}" FontSize="14"/>
                                                </Button>
                                                <Button Width="32"
                                                        Height="28"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        DataContext="{x:Bind}"
                                                        Click="ToggleArticleStar_Click"
                                                        x:Uid="RssPage_ToggleStar"
                                                        AutomationProperties.Name="Toggle starred">
                                                    <FontIcon Glyph="{x:Bind StarGlyph}" FontSize="14"/>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid x:Name="ArticleReaderPanel"
                          Grid.RowSpan="2"
                          RowSpacing="10"
                          Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Uid="RssPage_BtnBackToList"
                                    Width="36"
                                    Height="32"
                                    Padding="0"
                                    Click="BackToArticleListButton_Click">
                                <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                            </Button>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock x:Name="ReaderTitleText" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="ReaderMetaText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="ReaderPrivacyText" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button x:Uid="RssPage_OpenArticleInBrowserButton" Grid.Column="2" Click="OpenArticleInBrowserButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE774;" FontSize="14"/>
                                    <TextBlock x:Uid="RssPage_Browser" Text="浏览器"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid Grid.Row="1"
                              x:Name="RssArticleWebViewHost"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
