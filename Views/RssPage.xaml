<Page
    x:Class="Task_Flyout.Views.RssPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:Task_Flyout.Services"
    Background="Transparent">

    <Grid Padding="28" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2">
                <TextBlock Text="RSS" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock x:Name="SubtitleText"
                           Text="全部订阅文章"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <ProgressRing x:Name="LoadingRing"
                          Grid.Column="1"
                          Width="24"
                          Height="24"
                          IsActive="False"
                          Visibility="Collapsed"
                          VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12" MinHeight="520">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="190"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8"
                        Grid.RowSpan="3">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <TextBlock Text="订阅" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="AddFolderButton_Click"
                                    ToolTipService.ToolTip="添加文件夹">
                                <FontIcon Glyph="&#xE710;" FontSize="13"/>
                            </Button>
                        </Grid>
                        <TreeView Grid.Row="1"
                                  x:Name="RssTree"
                                  SelectionMode="Single"
                                  CanDragItems="True"
                                  CanReorderItems="True"
                                  AllowDrop="True"
                                  RightTapped="RssTree_RightTapped"
                                  ItemInvoked="RssTree_ItemInvoked"
                                  DragItemsCompleted="RssTree_DragItemsCompleted">
                            <TreeView.ContextFlyout>
                                <MenuFlyout Opening="RssTreeMenu_Opening">
                                    <MenuFlyoutItem x:Name="RenameRssTreeItem" Text="重命名" Click="RenameRssTreeItem_Click"/>
                                    <MenuFlyoutItem x:Name="DeleteRssTreeItem" Text="删除" Click="DeleteRssTreeItem_Click"/>
                                </MenuFlyout>
                            </TreeView.ContextFlyout>
                        </TreeView>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="3"
                           x:Name="SubscriptionStatusText"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <Grid Grid.Row="4">
                    <Button HorizontalAlignment="Stretch" Click="AddSubscriptionButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                            <TextBlock Text="添加订阅"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>

            <Border Grid.Column="1"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid x:Name="ArticleListHeader" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="ArticleListTitle" Text="全部文章" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ArticleListSubtitle" Text="向下滚动加载更多" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Click="RefreshButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                                <TextBlock Text="刷新"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Click="LoadMoreButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                                <TextBlock Text="更多"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ListView Grid.Row="1"
                              x:Name="ArticleList"
                              ItemsSource="{x:Bind Articles}"
                              SelectionMode="None"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="services:RssArticle">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="14"
                                        Margin="0,0,0,10"
                                        Tapped="Article_Tapped">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="112"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="112"
                                                Height="76"
                                                CornerRadius="6"
                                                Background="{ThemeResource LayerFillColorAltBrush}"
                                                Visibility="{x:Bind HasImage}">
                                            <Image Source="{x:Bind ImageSource}"
                                                   Stretch="UniformToFill"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <TextBlock Text="{x:Bind Title}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Bind FeedTitle}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock Text="·" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                                <TextBlock Text="{x:Bind PublishedText}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Summary}"
                                                       FontSize="13"
                                                       MaxLines="3"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap"
                                                       Visibility="{x:Bind HasSummary}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid x:Name="ArticleReaderPanel"
                          Grid.RowSpan="2"
                          RowSpacing="10"
                          Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Width="36"
                                    Height="32"
                                    Padding="0"
                                    Click="BackToArticleListButton_Click"
                                    ToolTipService.ToolTip="返回列表">
                                <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                            </Button>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock x:Name="ReaderTitleText" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="ReaderMetaText" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Click="OpenArticleInBrowserButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE774;" FontSize="14"/>
                                    <TextBlock Text="浏览器"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <WebView2 Grid.Row="1"
                                  x:Name="RssArticleWebView"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
