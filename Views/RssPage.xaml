<Page
    x:Class="Task_Flyout.Views.RssPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:Task_Flyout.Services"
    Background="Transparent">

    <Grid Padding="28" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2">
                <TextBlock Text="RSS" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock x:Name="SubtitleText"
                           Text="全部订阅文章"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <ProgressRing x:Name="LoadingRing"
                          Grid.Column="1"
                          Width="24"
                          Height="24"
                          IsActive="False"
                          Visibility="Collapsed"
                          VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12" MinHeight="520">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="190"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button x:Name="AllFeedsButton"
                        HorizontalAlignment="Stretch"
                        Click="AllFeedsButton_Click"
                        Content="全部文章"/>

                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8"
                        Grid.Row="1">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <TextBlock Text="文件夹" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Click="AddFolderButton_Click"
                                    ToolTipService.ToolTip="添加文件夹">
                                <FontIcon Glyph="&#xE710;" FontSize="13"/>
                            </Button>
                        </Grid>
                        <ListView Grid.Row="1"
                                  x:Name="FolderList"
                                  ItemsSource="{x:Bind Folders}"
                                  SelectionMode="Single"
                                  CanDragItems="True"
                                  CanReorderItems="True"
                                  AllowDrop="True"
                                  DragItemsCompleted="FolderList_DragItemsCompleted"
                                  SelectionChanged="FolderList_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="services:RssFolder">
                                    <Grid ColumnSpacing="8" Padding="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE8B7;" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Name}"
                                                   FontSize="14"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="2"
                                                Width="28"
                                                Height="28"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="DeleteFolderButton_Click"
                                                ToolTipService.ToolTip="删除文件夹">
                                            <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8">
                    <ListView x:Name="SubscriptionList"
                              ItemsSource="{x:Bind Subscriptions}"
                              SelectionMode="Single"
                              SelectionChanged="SubscriptionList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="services:RssSubscription">
                                <Grid ColumnSpacing="8" Padding="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{x:Bind Title}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Url}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Width="32"
                                            Height="32"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="MoveSubscriptionButton_Click"
                                            ToolTipService.ToolTip="设置文件夹">
                                        <FontIcon Glyph="&#xE8B7;" FontSize="14"/>
                                    </Button>
                                    <Button Grid.Column="2"
                                            Width="32"
                                            Height="32"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="DeleteSubscriptionButton_Click"
                                            ToolTipService.ToolTip="删除订阅">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <TextBlock Grid.Row="3"
                           x:Name="SubscriptionStatusText"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <Button Grid.Row="4" HorizontalAlignment="Stretch" Click="AddSubscriptionButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock Text="添加订阅"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Grid.Column="1"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="ArticleListTitle" Text="全部文章" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ArticleListSubtitle" Text="向下滚动加载更多" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Click="RefreshButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                                <TextBlock Text="刷新"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ListView Grid.Row="1"
                              x:Name="ArticleList"
                              ItemsSource="{x:Bind Articles}"
                              SelectionMode="None"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="services:RssArticle">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="14"
                                        Margin="0,0,0,10"
                                        Tapped="Article_Tapped">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="112"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="112"
                                                Height="76"
                                                CornerRadius="6"
                                                Background="{ThemeResource LayerFillColorAltBrush}"
                                                Visibility="{x:Bind HasImage}">
                                            <Image Source="{x:Bind ImageSource}"
                                                   Stretch="UniformToFill"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <TextBlock Text="{x:Bind Title}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Bind FeedTitle}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock Text="·" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                                <TextBlock Text="{x:Bind PublishedText}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Summary}"
                                                       FontSize="13"
                                                       MaxLines="3"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap"
                                                       Visibility="{x:Bind HasSummary}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
