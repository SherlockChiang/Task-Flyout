<Page
    x:Class="Task_Flyout.Views.MailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Task_Flyout.Services"
    Background="Transparent">

    <Grid Padding="28" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2">
                <TextBlock x:Name="TitleText" x:Uid="MailPage_Title" Text="邮件" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock x:Name="SubtitleText" x:Uid="MailPage_Subtitle" Text="账户、文件夹与收件箱" FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ToggleSwitch x:Uid="MailPage_UnreadOnlyToggle" x:Name="UnreadOnlyToggle" Header="仅未读" Toggled="UnreadOnlyToggle_Toggled"/>
                <Button x:Name="ComposeButton" Click="ComposeButton_Click"
                        AutomationProperties.Name="写邮件" ToolTipService.ToolTip="写邮件">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE724;" FontSize="14"/>
                        <TextBlock x:Uid="MailPage_Compose" Text="写邮件"/>
                    </StackPanel>
                </Button>
                <Button x:Name="RefreshButton" Click="RefreshButton_Click"
                        AutomationProperties.Name="刷新邮件" ToolTipService.ToolTip="刷新邮件">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock x:Uid="MailPage_Refresh" Text="刷新"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12" MinHeight="520">
            <Grid.ColumnDefinitions>
                <!-- Proportional so nothing is squeezed unreadable on small screens; the
                     side panes cap on wide screens and the message body keeps a readable floor. -->
                <ColumnDefinition Width="2*" MinWidth="190" MaxWidth="250"/>
                <ColumnDefinition Width="3*" MinWidth="280" MaxWidth="380"/>
                <ColumnDefinition Width="5*" MinWidth="340"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8">
                    <TreeView x:Name="AccountTree"
                              SelectionMode="Single"
                              CanDragItems="True"
                              CanReorderItems="True"
                              AllowDrop="True"
                              Expanding="AccountTree_Expanding"
                              SelectionChanged="AccountTree_SelectionChanged"
                              ItemInvoked="AccountTree_ItemInvoked"
                              DragItemsCompleted="AccountTree_DragItemsCompleted"/>
                </Border>

                <Button Grid.Row="1" x:Name="RemoveMailButton" HorizontalAlignment="Stretch" IsEnabled="False" Click="RemoveMailButton_Click"
                        AutomationProperties.Name="删除当前邮箱" ToolTipService.ToolTip="删除当前邮箱">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                        <TextBlock x:Uid="MailPage_DeleteAccount" Text="删除当前邮箱"/>
                    </StackPanel>
                </Button>

                <Button Grid.Row="2" x:Name="AddMailButton" HorizontalAlignment="Stretch" Click="AddMailButton_Click"
                        AutomationProperties.Name="添加新邮箱" ToolTipService.ToolTip="添加新邮箱">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock x:Uid="MailPage_AddAccount" Text="添加新邮箱"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Grid.Column="1"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12" Padding="6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Uid="MailPage_InboxHeader" x:Name="MessageListTitle" Text="收件箱" FontWeight="SemiBold"/>
                             <TextBlock x:Uid="MailPage_SelectFolderPrompt" x:Name="MessageListSubtitle" Text="请选择左侧文件夹" FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" AutomationProperties.LiveSetting="Polite"/>
                        </StackPanel>
                        <ProgressRing x:Name="LoadingRing" Grid.Column="1" IsActive="False" Width="24" Height="24"/>
                    </Grid>

                    <ListView Grid.Row="1"
                              x:Name="MailListView"
                              SelectionMode="Single"
                              SelectionChanged="MailListView_SelectionChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="4"/>
                                <Setter Property="MinHeight" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:MailItem">
                                <Grid MinHeight="82" ColumnSpacing="10" Padding="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind ReadMarker, Mode=OneWay}" FontSize="12"
                                               Foreground="{ThemeResource SystemAccentColor}"
                                               VerticalAlignment="Top" Margin="0,3,0,0"/>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="{x:Bind Sender}" FontWeight="SemiBold" FontSize="13"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Subject}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Preview}" FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Right">
                                        <TextBlock Text="{x:Bind ReceivedTime}" FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind AttachmentMarker}" FontSize="12" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button Grid.Row="2" x:Name="LoadMoreButton" Visibility="Collapsed"
                            HorizontalAlignment="Stretch" Click="LoadMoreButton_Click" Margin="4,0"
                            AutomationProperties.Name="加载更多邮件" ToolTipService.ToolTip="加载更多邮件">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74B;" FontSize="12"/>
                            <TextBlock x:Uid="MailPage_LoadMore" Text="加载更多邮件"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <Grid>
                    <StackPanel x:Name="EmptyDetailPanel" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE715;" FontSize="36" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        <TextBlock x:Uid="MailPage_SelectMailPrompt" Text="选择一封邮件查看预览" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <Grid x:Name="DetailPanel" Visibility="Collapsed" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="DetailSubject" FontSize="20" FontWeight="SemiBold" TextWrapping="WrapWholeWords"/>
                        <Grid Grid.Row="1" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <TextBlock x:Uid="MailPage_SenderLabel" Text="发件人" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <TextBlock x:Name="DetailSender" FontSize="14" TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="3" HorizontalAlignment="Right">
                                <TextBlock x:Uid="MailPage_DateLabel" Text="时间" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" HorizontalAlignment="Right"/>
                                <TextBlock x:Name="DetailTime" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Grid.Row="2" Spacing="3">
                            <TextBlock x:Uid="MailPage_ToHeader" Text="收件人" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            <TextBlock x:Name="DetailRecipient" FontSize="13" TextWrapping="WrapWholeWords"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Border Grid.Row="3" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                        <Border x:Name="RemoteImageBanner" Grid.Row="4" Visibility="Collapsed"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                CornerRadius="6" Padding="10,6">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE72E;" FontSize="14" VerticalAlignment="Center"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" x:Uid="MailPage_RemoteImagesBlocked" Text="已阻止远程图片和跟踪像素。显示图片仅本次生效；信任此来源会持续允许远程内容。"
                                           FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <Button Grid.Column="2" x:Name="ShowRemoteImagesButton" Click="ShowRemoteImagesButton_Click" Padding="10,4"
                                        AutomationProperties.Name="显示远程图片" ToolTipService.ToolTip="显示远程图片">
                                    <TextBlock x:Uid="MailPage_BtnShowImages" Text="显示图片" FontSize="13"/>
                                </Button>
                            </Grid>
                        </Border>
                        <Grid Grid.Row="5" MinHeight="320">
                            <Grid x:Name="DetailHtmlViewHost" Visibility="Collapsed"/>
                            <ScrollViewer x:Name="DetailTextScrollViewer" VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="DetailPreview" FontSize="14" TextWrapping="WrapWholeWords"
                                           LineHeight="22"/>
                            </ScrollViewer>
                        </Grid>
                        <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="8">
                            <Button x:Name="TrustSenderButton" HorizontalAlignment="Left" Click="TrustSenderButton_Click"
                                    AutomationProperties.Name="信任此来源" ToolTipService.ToolTip="信任此来源">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE72E;" FontSize="14"/>
                                    <TextBlock x:Uid="MailPage_BtnTrustSender" x:Name="TrustSenderButtonText" Text="信任此来源"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="ReplyButton" HorizontalAlignment="Left" Click="ReplyButton_Click"
                                    AutomationProperties.Name="回复邮件" ToolTipService.ToolTip="回复邮件">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE97A;" FontSize="14"/>
                                    <TextBlock x:Uid="MailPage_BtnReply" Text="回复"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="OpenInBrowserButton" HorizontalAlignment="Left" Click="OpenInBrowserButton_Click"
                                    AutomationProperties.Name="在浏览器中打开邮件" ToolTipService.ToolTip="在浏览器中打开邮件">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8A7;" FontSize="14"/>
                                    <TextBlock x:Uid="MailPage_BtnOpenInBrowser" Text="在浏览器中打开"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="AddAccountPanel" Visibility="Collapsed"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="560" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="18">
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="AddTitleText" x:Uid="MailPage_AddAccountTitle" Text="添加邮箱账户" FontSize="24" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="AddSubtitleText" x:Uid="MailPage_AddAccountSubtitle" Text="选择邮箱类型。Outlook 和 Gmail 使用 OAuth；IMAP 需要填写服务器设置。"
                                               TextWrapping="WrapWholeWords"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="AddOutlookButton" Padding="14" HorizontalAlignment="Stretch" Click="AddOutlookButton_Click"
                                            AutomationProperties.Name="添加 Outlook 邮箱" ToolTipService.ToolTip="添加 Outlook 邮箱">
                                        <StackPanel Spacing="8">
                                            <FontIcon Glyph="&#xE715;" FontSize="24"/>
                                            <TextBlock Text="Outlook" FontWeight="SemiBold"/>
                                            <TextBlock x:Uid="MailPage_BtnMSAccount" Text="Microsoft 账户" FontSize="12" TextWrapping="WrapWholeWords"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="1" x:Name="AddGmailButton" Padding="14" HorizontalAlignment="Stretch" Click="AddGmailButton_Click"
                                            AutomationProperties.Name="添加 Gmail 邮箱" ToolTipService.ToolTip="添加 Gmail 邮箱">
                                        <StackPanel Spacing="8">
                                            <FontIcon Glyph="&#xE77B;" FontSize="24"/>
                                            <TextBlock Text="Gmail" FontWeight="SemiBold"/>
                                            <TextBlock x:Uid="MailPage_BtnGoogleAccount" Text="Google OAuth" FontSize="12" TextWrapping="WrapWholeWords"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="2" x:Name="AddImapButton" Padding="14" HorizontalAlignment="Stretch" Click="AddImapButton_Click"
                                            AutomationProperties.Name="添加 IMAP 邮箱" ToolTipService.ToolTip="添加 IMAP 邮箱">
                                        <StackPanel Spacing="8">
                                            <FontIcon Glyph="&#xE8D4;" FontSize="24"/>
                                            <TextBlock Text="IMAP" FontWeight="SemiBold"/>
                                            <TextBlock x:Uid="MailPage_BtnCustomAccount" Text="自定义邮箱" FontSize="12" TextWrapping="WrapWholeWords"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <StackPanel x:Name="ImapSettingsPanel" Visibility="Collapsed" Spacing="10">
                                    <TextBox x:Name="ImapDisplayNameBox" x:Uid="MailPage_ImapDisplayName" Header="显示名称" PlaceholderText="Work Mail"/>
                                    <TextBox x:Name="ImapAddressBox" x:Uid="MailPage_ImapAddress" Header="邮箱地址" PlaceholderText="name@example.com"/>
                                    <TextBox x:Name="ImapUserNameBox" x:Uid="MailPage_ImapUserName" Header="用户名" PlaceholderText="name@example.com"/>
                                    <PasswordBox x:Name="ImapPasswordBox" x:Uid="MailPage_ImapPassword" Header="密码或应用专用密码"/>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ImapHostBox" x:Uid="MailPage_ImapHost" Header="IMAP 服务器" PlaceholderText="imap.example.com"/>
                                        <NumberBox Grid.Column="1" x:Name="ImapPortBox" x:Uid="MailPage_ImapPort" Header="端口" Value="993"
                                                   Minimum="1" Maximum="65535" SpinButtonPlacementMode="Inline"/>
                                    </Grid>
                                    <ToggleSwitch x:Name="ImapSslToggle" x:Uid="MailPage_ImapSsl" Header="使用 SSL/TLS" IsOn="True"/>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SmtpHostBox" x:Uid="MailPage_SmtpHost" Header="SMTP 服务器" PlaceholderText="smtp.example.com"/>
                                        <NumberBox Grid.Column="1" x:Name="SmtpPortBox" x:Uid="MailPage_SmtpPort" Header="端口" Value="587"
                                                   Minimum="1" Maximum="65535" SpinButtonPlacementMode="Inline"/>
                                    </Grid>
                                    <TextBox x:Name="SmtpUserNameBox" x:Uid="MailPage_SmtpUserName" Header="SMTP 用户名" PlaceholderText="默认使用 IMAP 用户名"/>
                                    <ToggleSwitch x:Name="SmtpSslToggle" x:Uid="MailPage_SmtpSsl" Header="SMTP 使用 SSL/TLS" IsOn="False"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                        <Button x:Uid="MailPage_BtnCancel" Content="取消" Click="CancelImapButton_Click"
                                                AutomationProperties.Name="取消 IMAP 设置" ToolTipService.ToolTip="取消 IMAP 设置"/>
                                        <Button x:Name="SaveImapButton" x:Uid="MailPage_BtnSaveImap" Content="连接并保存 IMAP 账户" Click="SaveImapButton_Click"
                                                AutomationProperties.Name="连接并保存 IMAP 账户" ToolTipService.ToolTip="连接并保存 IMAP 账户"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock x:Name="AddStatusText" Text="" FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid x:Name="ComposePanel" Visibility="Collapsed"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      HorizontalScrollMode="Disabled">
                            <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Top" Spacing="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="ComposeTitleText" x:Uid="MailPage_ComposeTitle" Text="写邮件" FontSize="24" FontWeight="SemiBold"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="CancelComposeButton" x:Uid="MailPage_BtnCancelCompose" Content="取消" Click="CancelComposeButton_Click"
                                                AutomationProperties.Name="取消写邮件" ToolTipService.ToolTip="取消写邮件"/>
                                        <Button x:Name="SendComposeButton" Click="SendComposeButton_Click"
                                                AutomationProperties.Name="发送邮件" ToolTipService.ToolTip="发送邮件">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE724;" FontSize="14"/>
                                                <TextBlock x:Uid="MailPage_TextSend" Text="发送"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                <TextBlock x:Uid="MailPage_ComposeConsentHint" Text="Gmail/Outlook 首次发送邮件时可能会要求额外授权发送权限。" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords"/>
                                <ComboBox x:Name="ComposeFromBox" x:Uid="MailPage_ComposeFrom" Header="发件人" HorizontalAlignment="Stretch"/>
                                <TextBox x:Name="ComposeToBox" x:Uid="MailPage_ComposeTo" Header="收件人" PlaceholderText="name@example.com; other@example.com"/>
                                <TextBox x:Name="ComposeSubjectBox" x:Uid="MailPage_ComposeSubject" Header="标题"/>
                                <TextBox x:Name="ComposeBodyBox" x:Uid="MailPage_ComposeBody" Header="内容" AcceptsReturn="True"
                                         TextWrapping="Wrap" MinHeight="220"/>
                                 <TextBlock x:Name="ComposeStatusText" FontSize="13"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="WrapWholeWords" AutomationProperties.LiveSetting="Polite"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
