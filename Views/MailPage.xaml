<Page
    x:Class="Task_Flyout.Views.MailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Task_Flyout.Services"
    Background="Transparent">

    <Grid Padding="28" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="2">
                <TextBlock x:Name="TitleText" Text="邮件" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock x:Name="SubtitleText" Text="账户、文件夹与收件箱" FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ToggleSwitch x:Name="UnreadOnlyToggle" Header="仅未读" Toggled="UnreadOnlyToggle_Toggled"/>
                <Button x:Name="ComposeButton" Click="ComposeButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE724;" FontSize="14"/>
                        <TextBlock Text="写邮件"/>
                    </StackPanel>
                </Button>
                <Button x:Name="RefreshButton" Click="RefreshButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                        <TextBlock Text="刷新"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="12" MinHeight="520">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8">
                    <TreeView x:Name="AccountTree"
                              SelectionMode="Single"
                              Expanding="AccountTree_Expanding"
                              ItemInvoked="AccountTree_ItemInvoked"/>
                </Border>

                <Button Grid.Row="1" x:Name="RemoveMailButton" HorizontalAlignment="Stretch" IsEnabled="False" Click="RemoveMailButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                        <TextBlock Text="删除当前邮箱"/>
                    </StackPanel>
                </Button>

                <Button Grid.Row="2" x:Name="AddMailButton" HorizontalAlignment="Stretch" Click="AddMailButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock Text="添加新邮箱"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Grid.Column="1"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12" Padding="6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="MessageListTitle" Text="收件箱" FontWeight="SemiBold"/>
                            <TextBlock x:Name="MessageListSubtitle" Text="请选择左侧文件夹" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <ProgressRing x:Name="LoadingRing" Grid.Column="1" IsActive="False" Width="24" Height="24"/>
                    </Grid>

                    <ListView Grid.Row="1"
                              x:Name="MailListView"
                              SelectionMode="Single"
                              SelectionChanged="MailListView_SelectionChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="4"/>
                                <Setter Property="MinHeight" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:MailItem">
                                <Grid MinHeight="82" ColumnSpacing="10" Padding="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind ReadMarker}" FontSize="12"
                                               Foreground="{ThemeResource SystemAccentColor}"
                                               VerticalAlignment="Top" Margin="0,3,0,0"/>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="{x:Bind Sender}" FontWeight="SemiBold" FontSize="13"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Subject}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Preview}" FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Right">
                                        <TextBlock Text="{x:Bind ReceivedTime}" FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind AttachmentMarker}" FontSize="12" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <Grid>
                    <StackPanel x:Name="EmptyDetailPanel" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE715;" FontSize="36" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        <TextBlock Text="选择一封邮件查看预览" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <Grid x:Name="DetailPanel" Visibility="Collapsed" RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="DetailSubject" FontSize="20" FontWeight="SemiBold" TextWrapping="WrapWholeWords"/>
                        <Grid Grid.Row="1" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="3">
                                <TextBlock Text="发件人" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <TextBlock x:Name="DetailSender" FontSize="14" TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="3" HorizontalAlignment="Right">
                                <TextBlock Text="时间" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" HorizontalAlignment="Right"/>
                                <TextBlock x:Name="DetailTime" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>
                        <Border Grid.Row="2" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                        <Grid Grid.Row="3" MinHeight="320">
                            <WebView2 x:Name="DetailHtmlView" Visibility="Collapsed"/>
                            <ScrollViewer x:Name="DetailTextScrollViewer" VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="DetailPreview" FontSize="14" TextWrapping="WrapWholeWords"
                                           LineHeight="22"/>
                            </ScrollViewer>
                        </Grid>
                        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8">
                            <Button x:Name="TrustSenderButton" HorizontalAlignment="Left" Click="TrustSenderButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE72E;" FontSize="14"/>
                                    <TextBlock x:Name="TrustSenderButtonText" Text="信任此来源"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="ReplyButton" HorizontalAlignment="Left" Click="ReplyButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE97A;" FontSize="14"/>
                                    <TextBlock Text="回复"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="OpenInBrowserButton" HorizontalAlignment="Left" Click="OpenInBrowserButton_Click">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8A7;" FontSize="14"/>
                                    <TextBlock Text="在浏览器中打开"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="AddAccountPanel" Visibility="Collapsed"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="560" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="18">
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="AddTitleText" Text="添加邮箱账户" FontSize="24" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="AddSubtitleText" Text="选择邮箱类型。Outlook 和 Gmail 使用 OAuth；IMAP 需要填写服务器设置。"
                                               TextWrapping="WrapWholeWords"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="AddOutlookButton" Padding="14" HorizontalAlignment="Stretch" Click="AddOutlookButton_Click">
                                        <StackPanel Spacing="8">
                                            <FontIcon Glyph="&#xE715;" FontSize="24"/>
                                            <TextBlock Text="Outlook" FontWeight="SemiBold"/>
                                            <TextBlock Text="Microsoft 账户" FontSize="12" TextWrapping="WrapWholeWords"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="1" x:Name="AddGmailButton" Padding="14" HorizontalAlignment="Stretch" Click="AddGmailButton_Click">
                                        <StackPanel Spacing="8">
                                            <FontIcon Glyph="&#xE77B;" FontSize="24"/>
                                            <TextBlock Text="Gmail" FontWeight="SemiBold"/>
                                            <TextBlock Text="Google OAuth" FontSize="12" TextWrapping="WrapWholeWords"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="2" x:Name="AddImapButton" Padding="14" HorizontalAlignment="Stretch" Click="AddImapButton_Click">
                                        <StackPanel Spacing="8">
                                            <FontIcon Glyph="&#xE8D4;" FontSize="24"/>
                                            <TextBlock Text="IMAP" FontWeight="SemiBold"/>
                                            <TextBlock Text="自定义邮箱" FontSize="12" TextWrapping="WrapWholeWords"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <StackPanel x:Name="ImapSettingsPanel" Visibility="Collapsed" Spacing="10">
                                    <TextBox x:Name="ImapDisplayNameBox" Header="显示名称" PlaceholderText="Work Mail"/>
                                    <TextBox x:Name="ImapAddressBox" Header="邮箱地址" PlaceholderText="name@example.com"/>
                                    <TextBox x:Name="ImapUserNameBox" Header="用户名" PlaceholderText="name@example.com"/>
                                    <PasswordBox x:Name="ImapPasswordBox" Header="密码或应用专用密码"/>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ImapHostBox" Header="IMAP 服务器" PlaceholderText="imap.example.com"/>
                                        <NumberBox Grid.Column="1" x:Name="ImapPortBox" Header="端口" Value="993"
                                                   Minimum="1" Maximum="65535" SpinButtonPlacementMode="Inline"/>
                                    </Grid>
                                    <ToggleSwitch x:Name="ImapSslToggle" Header="使用 SSL/TLS" IsOn="True"/>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SmtpHostBox" Header="SMTP 服务器" PlaceholderText="smtp.example.com"/>
                                        <NumberBox Grid.Column="1" x:Name="SmtpPortBox" Header="端口" Value="587"
                                                   Minimum="1" Maximum="65535" SpinButtonPlacementMode="Inline"/>
                                    </Grid>
                                    <TextBox x:Name="SmtpUserNameBox" Header="SMTP 用户名" PlaceholderText="默认使用 IMAP 用户名"/>
                                    <ToggleSwitch x:Name="SmtpSslToggle" Header="SMTP 使用 SSL/TLS" IsOn="False"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                        <Button Content="取消" Click="CancelImapButton_Click"/>
                                        <Button x:Name="SaveImapButton" Content="连接并保存 IMAP 账户" Click="SaveImapButton_Click"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock x:Name="AddStatusText" Text="" FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid x:Name="ComposePanel" Visibility="Collapsed"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      HorizontalScrollMode="Disabled">
                            <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Top" Spacing="12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="ComposeTitleText" Text="写邮件" FontSize="24" FontWeight="SemiBold"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <Button Content="取消" Click="CancelComposeButton_Click"/>
                                        <Button x:Name="SendComposeButton" Click="SendComposeButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE724;" FontSize="14"/>
                                                <TextBlock Text="发送"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                                <ComboBox x:Name="ComposeFromBox" Header="发件人" HorizontalAlignment="Stretch"/>
                                <TextBox x:Name="ComposeToBox" Header="收件人" PlaceholderText="name@example.com; other@example.com"/>
                                <TextBox x:Name="ComposeSubjectBox" Header="标题"/>
                                <TextBox x:Name="ComposeBodyBox" Header="内容" AcceptsReturn="True"
                                         TextWrapping="Wrap" MinHeight="220"/>
                                <TextBlock x:Name="ComposeStatusText" FontSize="13"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="WrapWholeWords"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
