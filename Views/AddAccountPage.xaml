<Page
    x:Class="Task_Flyout.Views.AddAccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
    <Grid Padding="24" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="500">
        <StackPanel Spacing="24">
            <TextBlock x:Uid="AddAccount_Title" Text="添加账户" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock x:Uid="AddAccount_Subtitle" Text="选择要连接的账户类型" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="14"/>

            <Border Padding="16" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="AddAccount_ChecklistTitle" Text="Setup checklist" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock x:Name="ChecklistText" Text="" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                    <TextBlock x:Name="HealthText" Text="" TextWrapping="Wrap" FontSize="12"/>
                    <StackPanel Spacing="8">
                        <Button x:Name="RetrySyncButton" x:Uid="AddAccount_RetrySync" Content="Retry sync" Click="RetrySyncButton_Click" Padding="10,4"/>
                        <Button x:Name="OpenMailSetupButton" Click="OpenMailSetupButton_Click" Padding="10,4">
                            <TextBlock x:Uid="AddAccount_OpenMailSetup" Text="Open Mail setup" FontSize="12"/>
                        </Button>
                        <Button x:Name="OpenWeatherSetupButton" Click="OpenWeatherSetupButton_Click" Padding="10,4">
                            <TextBlock x:Uid="AddAccount_OpenWeatherSetup" Text="Open Weather setup" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Google -->
            <Button x:Name="BtnGoogle" HorizontalAlignment="Stretch" Padding="16" Click="BtnGoogle_Click"
                    HorizontalContentAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <FontIcon Glyph="&#xE77B;" Foreground="#EA4335" FontSize="24"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock x:Uid="AddAccount_GoogleTitle" Text="Google" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Uid="AddAccount_GoogleDesc" Text="Google 日历与任务" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Button>

            <!-- Microsoft -->
            <Button x:Name="BtnMicrosoft" HorizontalAlignment="Stretch" Padding="16" Click="BtnMicrosoft_Click"
                    HorizontalContentAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <FontIcon Glyph="&#xE77B;" Foreground="#0078D4" FontSize="24"/>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <TextBlock x:Uid="AddAccount_MSTitle" Text="Microsoft" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Uid="AddAccount_MSDesc" Text="Outlook 日历与 To Do" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Button>

            <ProgressRing x:Name="AuthProgress" IsActive="False" Width="32" Height="32"/>
            <TextBlock x:Name="StatusText" Text="" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"
                       HorizontalAlignment="Center"/>
            <StackPanel x:Name="OnboardingActions" Spacing="8" HorizontalAlignment="Stretch">
                <Button x:Uid="AddAccount_Skip" Content="Skip for now" Click="SkipButton_Click"/>
                <Button x:Uid="AddAccount_Finish" Content="Finish setup" Style="{StaticResource AccentButtonStyle}" Click="FinishButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Page>
