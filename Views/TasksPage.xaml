<Page
    x:Class="Task_Flyout.Views.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Task_Flyout.Models"
    xmlns:views="using:Task_Flyout.Views"
    Background="Transparent">

    <Page.Resources>
        <views:ProviderToBrushConverter x:Key="ProviderToBrushConverter"/>
        <views:BoolToStrikethroughConverter x:Key="BoolToStrikethroughConverter"/>
        <views:TaskCompletedOpacityConverter x:Key="TaskCompletedOpacityConverter"/>
    </Page.Resources>

    <Grid Background="#01000000">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="AccountColumn" Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="AccountPane" Grid.Column="0"
              Background="{ThemeResource LayerFillColorAltBrush}"
              BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
              BorderThickness="0,0,1,0"
              Padding="16,32,16,24"
              RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="4,0,0,8">
                <TextBlock Text="任务账户" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" Width="32" Height="32" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        Click="ToggleAccountPane_Click"
                        ToolTipService.ToolTip="折叠账户">
                    <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsRepeater x:Name="AccountListRepeater">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="4"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Expander HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Stretch"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Padding="0"
                                      IsExpanded="True">
                                <Expander.Resources>
                                    <SolidColorBrush x:Key="ExpanderHeaderBackground" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ExpanderHeaderBackgroundPointerOver" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ExpanderHeaderBackgroundPressed" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ExpanderHeaderBorderBrush" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ExpanderHeaderBorderBrushPointerOver" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ExpanderHeaderBorderBrushPressed" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ExpanderContentBackground" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ExpanderContentBorderBrush" Color="Transparent"/>
                                </Expander.Resources>

                                <Expander.Header>
                                    <Grid HorizontalAlignment="Stretch" Margin="0,0,8,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE77B;" FontSize="15"
                                                  Margin="0,0,12,0"
                                                  Foreground="{ThemeResource SystemAccentColor}"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" FontWeight="Bold" FontSize="14"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding ProviderName}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="2" Padding="4"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Tag="{Binding ProviderName}"
                                                Click="BtnRemoveAccount_Click"
                                                ToolTipService.ToolTip="移除账户"
                                                VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE711;" FontSize="12"
                                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                        </Button>
                                    </Grid>
                                </Expander.Header>

                                <Expander.Content>
                                    <Grid Margin="32,0,0,8" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="16" Height="16" CornerRadius="8"
                                                VerticalAlignment="Center"
                                                Background="{Binding TaskColorHex, Converter={StaticResource ProviderToBrushConverter}}"/>
                                        <TextBlock Grid.Column="1" Text="待办任务"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <ToggleSwitch Grid.Column="2"
                                                      IsOn="{Binding ShowTasks, Mode=TwoWay}"
                                                      OffContent=""
                                                      OnContent=""
                                                      MinWidth="0"
                                                      Margin="0"
                                                      Toggled="AccountToggle_Toggled"
                                                      VerticalAlignment="Center"/>
                                    </Grid>
                                </Expander.Content>
                            </Expander>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <Button Grid.Row="2" HorizontalAlignment="Stretch" Click="BtnAddAccount_Click" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                    <TextBlock Text="添加账户"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="3" Content="强制立即同步" HorizontalAlignment="Stretch" Click="BtnForceSync_Click"/>
        </Grid>

        <Grid Grid.Column="1" Padding="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button x:Name="ToggleAccountPaneButton"
                            Width="40"
                            Height="36"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="ToggleAccountPane_Click"
                            ToolTipService.ToolTip="展开账户">
                        <FontIcon x:Name="ToggleAccountPaneIcon" Glyph="&#xE76C;" FontSize="14"/>
                    </Button>
                    <StackPanel Spacing="2">
                        <TextBlock Text="任务" FontSize="28" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TaskSummaryText"
                                   Text="正在加载任务"
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
                <ProgressRing x:Name="SyncProgress"
                              Width="24"
                              Height="24"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              IsActive="False"
                              Visibility="Collapsed"/>
                <Button HorizontalAlignment="Right"
                        Margin="0,0,36,0"
                        Click="AddTaskButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock Text="添加任务"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Grid Grid.Row="1" RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="PendingHeaderText" Text="待完成" FontSize="18" FontWeight="SemiBold"/>
                    <ListView Grid.Row="1"
                              x:Name="PendingTasksList"
                              ItemsSource="{x:Bind PendingTasks}"
                              MaxHeight="360"
                              SelectionMode="None"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:AgendaItem">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="14"
                                        Margin="0,0,0,10">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{x:Bind IsCompleted, Mode=TwoWay}"
                                                  Click="TaskCheckBox_Click"
                                                  VerticalAlignment="Top"
                                                  MinWidth="0"
                                                  Padding="0"
                                                  Margin="0,2,0,0"/>
                                        <Border Grid.Column="1"
                                                Background="{x:Bind ColorHex, Converter={StaticResource ProviderToBrushConverter}}"
                                                CornerRadius="2"
                                                VerticalAlignment="Stretch"/>
                                        <StackPanel Grid.Column="2" Spacing="6">
                                            <TextBlock Text="{x:Bind Title}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Bind Provider}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock Text="·" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                                <TextBlock Text="{x:Bind DateKey}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Description}" FontSize="13" MaxLines="2"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap"
                                                       Visibility="{x:Bind HasDescription}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="3"
                                                Width="32"
                                                Height="32"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="DeleteTaskButton_Click"
                                                ToolTipService.ToolTip="删除任务">
                                            <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="PendingEmptyText"
                               Grid.Row="1"
                               Text="已经没有未完成任务"
                               HorizontalAlignment="Center"
                               Margin="0,24,0,28"
                               FontSize="14"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Visibility="Collapsed"/>
                </Grid>

                <Border Grid.Row="1" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                <Grid Grid.Row="2" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="CompletedHeaderText" Text="已完成" FontSize="18" FontWeight="SemiBold"/>
                    <ListView Grid.Row="1"
                              x:Name="CompletedTasksList"
                              ItemsSource="{x:Bind CompletedTasks}"
                              SelectionMode="None"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:AgendaItem">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="14"
                                        Margin="0,0,0,10"
                                        Opacity="0.78">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{x:Bind IsCompleted, Mode=TwoWay}"
                                                  Click="TaskCheckBox_Click"
                                                  VerticalAlignment="Top"
                                                  MinWidth="0"
                                                  Padding="0"
                                                  Margin="0,2,0,0"/>
                                        <Border Grid.Column="1"
                                                Background="{x:Bind ColorHex, Converter={StaticResource ProviderToBrushConverter}}"
                                                CornerRadius="2"
                                                VerticalAlignment="Stretch"/>
                                        <StackPanel Grid.Column="2" Spacing="6">
                                            <TextBlock Text="{x:Bind Title}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"
                                                       TextDecorations="{x:Bind IsCompleted, Converter={StaticResource BoolToStrikethroughConverter}}"
                                                       Opacity="{x:Bind IsCompleted, Converter={StaticResource TaskCompletedOpacityConverter}}"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Bind Provider}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock Text="·" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                                <TextBlock Text="{x:Bind DateKey}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Description}" FontSize="13" MaxLines="2"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap"
                                                       Visibility="{x:Bind HasDescription}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="3"
                                                Width="32"
                                                Height="32"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="DeleteTaskButton_Click"
                                                ToolTipService.ToolTip="删除任务">
                                            <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
