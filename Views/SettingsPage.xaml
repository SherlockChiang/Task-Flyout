<Page
    x:Class="Task_Flyout.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer Padding="40">
        <StackPanel Spacing="28" MaxWidth="800" HorizontalAlignment="Left">
            <TextBlock x:Uid="SettingsPage_Title" Text="设置" Style="{StaticResource TitleTextBlockStyle}"/>

            <StackPanel Spacing="8">
                <TextBlock x:Uid="SettingsPage_Appearance" Text="外观与语言" FontWeight="SemiBold" FontSize="16"/>

                <ComboBox x:Uid="SettingsPage_ThemeMode" x:Name="ThemeComboBox" Header="应用主题" SelectedIndex="0" Width="200" SelectionChanged="ThemeComboBox_SelectionChanged">
                    <ComboBoxItem x:Uid="Theme_System" Content="跟随系统"/>
                    <ComboBoxItem x:Uid="Theme_Light" Content="浅色"/>
                    <ComboBoxItem x:Uid="Theme_Dark" Content="深色"/>
                </ComboBox>

                <ComboBox x:Uid="SettingsPage_Language" x:Name="LanguageComboBox" Header="界面语言" SelectedIndex="0" Width="200" SelectionChanged="LanguageComboBox_SelectionChanged">
                    <ComboBoxItem x:Uid="Lang_System" Content="跟随系统"/>
                    <ComboBoxItem Content="简体中文" Tag="zh-Hans"/>
                    <ComboBoxItem Content="English" Tag="en-US"/>
                </ComboBox>
            </StackPanel>

            <!-- Color Palette Section -->
            <StackPanel Spacing="12">
                <TextBlock x:Uid="SettingsPage_ColorPalette" Text="莫奈调色盘" FontWeight="SemiBold" FontSize="16"/>
                <TextBlock x:Uid="SettingsPage_ColorPaletteDesc" Text="为每个日历和任务列表指定代表色，颜色将同步应用到侧栏与日历视图。" FontSize="13" Opacity="0.7" TextWrapping="Wrap"/>
                <StackPanel x:Name="ColorPalettePanel" Spacing="8"/>
            </StackPanel>

            <!-- Clock Display Section -->
            <StackPanel Spacing="8">
                <TextBlock x:Uid="SettingsPage_Clock" Text="时钟显示" FontWeight="SemiBold" FontSize="16"/>
                <ToggleSwitch x:Uid="SettingsPage_ShowSeconds" x:Name="ShowSecondsToggle" Header="在浮窗时钟中显示秒" IsOn="False" Toggled="ShowSecondsToggle_Toggled"/>
            </StackPanel>

            <!-- Notification Section -->
            <StackPanel Spacing="8">
                <TextBlock x:Uid="SettingsPage_Notification" Text="通知提醒" FontWeight="SemiBold" FontSize="16"/>
                <ToggleSwitch x:Uid="SettingsPage_NotifyToggle" x:Name="NotifyToggle" Header="日程开始前弹出通知" IsOn="True" Toggled="NotifyToggle_Toggled"/>
                
                <ComboBox x:Uid="SettingsPage_NotifyTime" x:Name="NotifyTimeComboBox" Header="提前提醒时间" Width="200" SelectionChanged="NotifyTimeComboBox_SelectionChanged" />
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="邮件同步" FontWeight="SemiBold" FontSize="16"/>
                <ToggleSwitch x:Name="MailPollingToggle" Header="定时抓取新邮件并显示 Windows 通知" IsOn="True" Toggled="MailPollingToggle_Toggled"/>
                <ComboBox x:Name="MailPollingIntervalComboBox" Header="新邮件检查间隔" Width="200" SelectionChanged="MailPollingIntervalComboBox_SelectionChanged" />
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock x:Uid="SettingsPage_System" Text="系统与常规" FontWeight="SemiBold" FontSize="16"/>
                
                <ComboBox x:Uid="SettingsPage_SyncInterval" x:Name="SyncIntervalComboBox" Header="自动同步间隔" Width="200" SelectionChanged="SyncIntervalComboBox_SelectionChanged" />
                
                <ToggleSwitch x:Uid="SettingsPage_Startup" x:Name="StartupToggle" Header="开机时自动启动" IsOn="False" Toggled="StartupToggle_Toggled"/>
                <ToggleSwitch x:Uid="SettingsPage_Background" x:Name="BackgroundToggle" Header="关闭主窗口时最小化到托盘 (后台运行)" IsOn="True" Toggled="BackgroundToggle_Toggled"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
