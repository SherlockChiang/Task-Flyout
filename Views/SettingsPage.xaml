<Page
    x:Class="Task_Flyout.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer Padding="40">
        <StackPanel Spacing="28" MaxWidth="800" HorizontalAlignment="Left">
            <TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}"/>

            <StackPanel Spacing="8">
                <TextBlock Text="外观与语言" FontWeight="SemiBold" FontSize="16"/>
                <ComboBox x:Name="ThemeComboBox" Header="应用主题" SelectedIndex="0" Width="200" SelectionChanged="ThemeComboBox_SelectionChanged">
                    <ComboBoxItem Content="跟随系统"/>
                    <ComboBoxItem Content="浅色"/>
                    <ComboBoxItem Content="深色"/>
                </ComboBox>
                <ComboBox x:Name="LanguageComboBox" Header="界面语言 (重启生效)" SelectedIndex="0" Width="200" SelectionChanged="LanguageComboBox_SelectionChanged">
                    <ComboBoxItem Content="跟随系统"/>
                    <ComboBoxItem Content="简体中文" Tag="zh-Hans"/>
                    <ComboBoxItem Content="English" Tag="en-US"/>
                </ComboBox>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>