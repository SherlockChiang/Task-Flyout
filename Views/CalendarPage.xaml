<Page
    x:Class="Task_Flyout.Views.CalendarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Task_Flyout.Models"
    xmlns:views="using:Task_Flyout.Views"
    Background="Transparent">

    <Page.Resources>
        <views:BoolToTodayBrushConverter x:Key="BoolToTodayBrushConverter"/>
        <views:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <views:BoolToStrikethroughConverter x:Key="BoolToStrikethroughConverter"/>
    </Page.Resources>

    <Grid Padding="32" Background="#01000000">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                <Button x:Name="BtnMonthYear" Content="2026年 3月" FontSize="24" FontWeight="Bold" Background="Transparent" BorderThickness="0" Padding="8,4">
                    <Button.Flyout>
                        <Flyout x:Name="MonthYearFlyout" Opened="MonthYearFlyout_Opened">
                            <StackPanel Spacing="16" Width="240">
                                <Grid>
                                    <Button Click="FlyoutPrevYear_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left">
                                        <SymbolIcon Symbol="Back"/>
                                    </Button>
                                    <TextBlock x:Name="FlyoutYearText" Text="2026年" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Button Click="FlyoutNextYear_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right">
                                        <SymbolIcon Symbol="Forward"/>
                                    </Button>
                                </Grid>
                                <GridView x:Name="FlyoutMonthGrid" IsItemClickEnabled="True" ItemClick="FlyoutMonthGrid_ItemClick" SelectionMode="None" HorizontalAlignment="Center">
                                    <GridView.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid MaximumRowsOrColumns="4" Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </GridView.ItemsPanel>
                                    <GridView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="48" Height="48" CornerRadius="4" Background="Transparent">
                                                <TextBlock Text="{Binding}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridView.ItemTemplate>
                                </GridView>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button Content="今天" Click="BtnToday_Click" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                <Button Click="BtnPrevMonth_Click" Background="Transparent" BorderThickness="0" VerticalAlignment="Center">
                    <SymbolIcon Symbol="Back"/>
                </Button>
                <Button Click="BtnNextMonth_Click" Background="Transparent" BorderThickness="0" VerticalAlignment="Center">
                    <SymbolIcon Symbol="Forward"/>
                </Button>
                <ProgressRing x:Name="SyncProgress" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="周日" HorizontalAlignment="Center" Opacity="0.6" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="周一" HorizontalAlignment="Center" Opacity="0.6" FontSize="12"/>
                <TextBlock Grid.Column="2" Text="周二" HorizontalAlignment="Center" Opacity="0.6" FontSize="12"/>
                <TextBlock Grid.Column="3" Text="周三" HorizontalAlignment="Center" Opacity="0.6" FontSize="12"/>
                <TextBlock Grid.Column="4" Text="周四" HorizontalAlignment="Center" Opacity="0.6" FontSize="12"/>
                <TextBlock Grid.Column="5" Text="周五" HorizontalAlignment="Center" Opacity="0.6" FontSize="12"/>
                <TextBlock Grid.Column="6" Text="周六" HorizontalAlignment="Center" Opacity="0.6" FontSize="12"/>
            </Grid>

            <GridView x:Name="CalendarGrid" Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ItemsSource="{x:Bind DayCells}" SizeChanged="CalendarGrid_SizeChanged"
                      SelectionMode="Single" IsItemClickEnabled="True" ItemClick="CalendarGrid_ItemClick">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid x:Name="WrapGrid" Orientation="Horizontal" MaximumRowsOrColumns="7"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>

                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:DayCellViewModel">
                        <Border Margin="2" Padding="8" CornerRadius="8"
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{x:Bind IsToday, Mode=OneWay, Converter={StaticResource BoolToTodayBrushConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="{x:Bind DayNumber}" FontWeight="Bold" 
                                           Opacity="{x:Bind IsCurrentMonth, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}"/>

                                <ItemsControl Grid.Row="1" ItemsSource="{x:Bind Items}" Margin="0,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:AgendaItem">
                                            <Border Background="{ThemeResource SystemAccentColorLight3}" 
                                                    CornerRadius="4" Margin="0,1" Padding="4,2">
                                                <TextBlock Text="{x:Bind Title}" FontSize="11" Foreground="Black" TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>

        <Grid Grid.Column="1" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1,0,0,0" Padding="24,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TxtSideBarDate" Grid.Row="0" Text="全部日程" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>

            <ListView x:Name="SideBarAgendaList" Grid.Row="1" ItemsSource="{x:Bind SelectedDayItems}" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:AgendaItem">
                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{x:Bind Subtitle}" FontSize="13" Opacity="0.7" VerticalAlignment="Top" Margin="0,6,0,0" TextWrapping="Wrap"/>

                            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    CornerRadius="6" Padding="12">
                                <Grid>
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="{x:Bind Title}" Visibility="{x:Bind IsEvent}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        <CheckBox IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" Visibility="{x:Bind IsTask}" 
                                                  Content="{x:Bind Title}" FontSize="16" Click="TaskCheckBox_Click"/>
                                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,6,0,0" Visibility="{x:Bind HasLocation}">
                                            <FontIcon Glyph="&#xE710;" FontSize="12" Opacity="0.6"/>
                                            <TextBlock Text="{x:Bind Location}" FontSize="14" Opacity="0.6"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Padding="4" Margin="0,-4,-4,0">
                                        <FontIcon Glyph="&#xE712;" FontSize="14"/>
                                        <Button.Flyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="编辑" Icon="Edit" Click="EditItem_Click" DataContext="{x:Bind}"/>
                                                <MenuFlyoutItem Text="删除" Icon="Delete" Click="DeleteItem_Click" DataContext="{x:Bind}"/>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <ContentDialog x:Name="EditDialog" Title="编辑日程/任务" PrimaryButtonText="保存" CloseButtonText="取消" PrimaryButtonClick="EditDialog_PrimaryButtonClick">
            <StackPanel Spacing="16" Width="300">
                <TextBox x:Name="EditTxtTitle" Header="名称"/>
                <TextBox x:Name="EditTxtLocation" Header="地点 (选填)"/>
                <DatePicker x:Name="EditDatePicker" Header="日期"/>
                <TimePicker x:Name="EditTimePicker" Header="时间 (全天留空)"/>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>