<Page
    x:Class="Task_Flyout.Views.CalendarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Task_Flyout.Models"
    xmlns:views="using:Task_Flyout.Views"
    Background="Transparent">

    <Page.Resources>
        <views:BoolToTodayBrushConverter x:Key="BoolToTodayBrushConverter"/>
        <views:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <views:BoolToStrikethroughConverter x:Key="BoolToStrikethroughConverter"/>
        <views:ProviderToBrushConverter x:Key="ProviderToBrushConverter"/>
        <views:TaskCompletedOpacityConverter x:Key="TaskCompletedOpacityConverter"/>
        <views:ProviderToTextBrushConverter x:Key="ProviderToTextBrushConverter"/>
    </Page.Resources>

    <Grid Background="#01000000">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="AccountColumn" Width="260"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="TimelineColumn" Width="340"/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="AccountPane" Grid.Column="0" Background="{ThemeResource LayerFillColorAltBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="16,32,16,24" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="4,0,0,8">
                <TextBlock Text="日程账户" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" Width="32" Height="32" Padding="0" Background="Transparent" BorderThickness="0"
                        Click="ToggleAccountPane_Click" ToolTipService.ToolTip="折叠账户">
                    <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsRepeater x:Name="AccountListRepeater">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="4"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                      Background="Transparent" BorderThickness="0" Padding="0" IsExpanded="True">
                                <Expander.Resources>
                                    <SolidColorBrush x:Key="ExpanderHeaderBackground" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ExpanderHeaderBackgroundPointerOver" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ExpanderHeaderBackgroundPressed" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ExpanderHeaderBorderBrush" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ExpanderHeaderBorderBrushPointerOver" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ExpanderHeaderBorderBrushPressed" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ExpanderContentBackground" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ExpanderContentBorderBrush" Color="Transparent"/>
                                </Expander.Resources>

                                <Expander.Header>
                                    <Grid HorizontalAlignment="Stretch" Margin="0,0,8,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE77B;" FontSize="15" Margin="0,0,12,0"
                                                  Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"
                                                   Text="{Binding ProviderName}" TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="2" Padding="4" Background="Transparent" BorderThickness="0"
                                                Tag="{Binding ProviderName}" Click="BtnRemoveAccount_Click"
                                                ToolTipService.ToolTip="移除账户" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                        </Button>
                                    </Grid>
                                </Expander.Header>

                                <Expander.Content>
                                    <StackPanel Spacing="0" Margin="0,4,0,0">
                                        <ItemsRepeater ItemsSource="{Binding Calendars}">
                                            <ItemsRepeater.Layout>
                                                <StackLayout Spacing="0"/>
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="32,0,0,8" ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Width="16" Height="16" CornerRadius="8"
                                                                VerticalAlignment="Center"
                                                                Background="{Binding ColorHex, Converter={StaticResource ProviderToBrushConverter}}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" FontSize="13"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                        <ToggleSwitch Grid.Column="2" IsOn="{Binding IsVisible, Mode=TwoWay}"
                                                                      OffContent="" OnContent="" MinWidth="0" Margin="0"
                                                                      Toggled="CalendarToggle_Toggled" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>

                                        <Grid Margin="32,0,0,8" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="16" Height="16" CornerRadius="8"
                                                    VerticalAlignment="Center"
                                                    Background="{Binding TaskColorHex, Converter={StaticResource ProviderToBrushConverter}}"/>
                                            <TextBlock Grid.Column="1" Text="待办任务" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" FontSize="13"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <ToggleSwitch Grid.Column="2" IsOn="{Binding ShowTasks, Mode=TwoWay}"
                                                          OffContent="" OnContent="" MinWidth="0" Margin="0"
                                                          Toggled="AccountToggle_Toggled" Tag="{Binding ProviderName}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Expander.Content>
                            </Expander>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <Button Grid.Row="2" x:Name="BtnAddAccount" HorizontalAlignment="Stretch" Click="BtnAddAccount_Click" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                    <TextBlock Text="添加账户"/>
                </StackPanel>
            </Button>

            <Button Grid.Row="3" Content="强制立即同步" HorizontalAlignment="Stretch" Click="BtnForceSync_Click"/>
        </Grid>

        <Grid Grid.Column="1" Padding="32,32,24,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,24">
                <Button x:Name="ToggleAccountPaneButton" Width="40" Height="36" Padding="0" Background="Transparent" BorderThickness="0"
                        Click="ToggleAccountPane_Click" ToolTipService.ToolTip="显示/隐藏账户">
                    <FontIcon x:Name="ToggleAccountPaneIcon" Glyph="&#xE76B;" FontSize="12"/>
                </Button>
                <Button x:Name="BtnMonthYear" Content="2026年 3月" FontSize="28" FontWeight="Bold" Background="Transparent" BorderThickness="0" Padding="8,4" Margin="-8,0,0,0" Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                    <Button.Flyout>
                        <Flyout x:Name="MonthYearFlyout" Opened="MonthYearFlyout_Opened">
                            <StackPanel Spacing="16" Width="260" Padding="8">
                                <Grid>
                                    <Button Click="FlyoutPrevYear_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left">
                                        <SymbolIcon Symbol="Back"/>
                                    </Button>
                                    <TextBlock x:Name="FlyoutYearText" Text="2026年" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Button Click="FlyoutNextYear_Click" Background="Transparent" BorderThickness="0" HorizontalAlignment="Right">
                                        <SymbolIcon Symbol="Forward"/>
                                    </Button>
                                </Grid>
                                <GridView x:Name="FlyoutMonthGrid" IsItemClickEnabled="True" ItemClick="FlyoutMonthGrid_ItemClick" SelectionMode="None" HorizontalAlignment="Center">
                                    <GridView.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid MaximumRowsOrColumns="4" Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </GridView.ItemsPanel>
                                    <GridView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="52" Height="52" CornerRadius="6" Background="Transparent" Margin="2">
                                                <TextBlock Text="{Binding}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </GridView.ItemTemplate>
                                </GridView>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <Border Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" VerticalAlignment="Center" Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Click="BtnPrevMonth_Click" Background="Transparent" BorderThickness="0" Width="40" Height="36" CornerRadius="6,0,0,6">
                            <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                        </Button>
                        <MenuFlyoutSeparator Margin="0,8" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                        <Button Click="BtnNextMonth_Click" Background="Transparent" BorderThickness="0" Width="40" Height="36" CornerRadius="0,6,6,0">
                            <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </Border>
                <Button x:Uid="CalendarPage_BtnToday" Content="今天" Click="BtnToday_Click" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center" Margin="8,0,0,0" FontWeight="SemiBold" CornerRadius="6"/>
                <Button x:Name="ToggleTimelinePaneButton" Width="40" Height="36" Padding="0" Background="Transparent" BorderThickness="0"
                        Click="ToggleTimelinePane_Click" ToolTipService.ToolTip="显示/隐藏日程">
                    <FontIcon x:Name="ToggleTimelinePaneIcon" Glyph="&#xE76C;" FontSize="12"/>
                </Button>
                <ProgressRing x:Name="SyncProgress" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" Margin="16,0,0,0"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Uid="CalendarPage_Sun" Grid.Column="0" Text="周日" HorizontalAlignment="Center" Opacity="0.8" FontWeight="SemiBold" FontSize="13"/>
                <TextBlock x:Uid="CalendarPage_Mon" Grid.Column="1" Text="周一" HorizontalAlignment="Center" Opacity="0.8" FontWeight="SemiBold" FontSize="13"/>
                <TextBlock x:Uid="CalendarPage_Tue" Grid.Column="2" Text="周二" HorizontalAlignment="Center" Opacity="0.8" FontWeight="SemiBold" FontSize="13"/>
                <TextBlock x:Uid="CalendarPage_Wed" Grid.Column="3" Text="周三" HorizontalAlignment="Center" Opacity="0.8" FontWeight="SemiBold" FontSize="13"/>
                <TextBlock x:Uid="CalendarPage_Thu" Grid.Column="4" Text="周四" HorizontalAlignment="Center" Opacity="0.8" FontWeight="SemiBold" FontSize="13"/>
                <TextBlock x:Uid="CalendarPage_Fri" Grid.Column="5" Text="周五" HorizontalAlignment="Center" Opacity="0.8" FontWeight="SemiBold" FontSize="13"/>
                <TextBlock x:Uid="CalendarPage_Sat" Grid.Column="6" Text="周六" HorizontalAlignment="Center" Opacity="0.8" FontWeight="SemiBold" FontSize="13"/>
            </Grid>

            <GridView x:Name="CalendarGrid" Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ItemsSource="{x:Bind DayCells}" SizeChanged="CalendarGrid_SizeChanged" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="CalendarGrid_ItemClick" ScrollViewer.VerticalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollMode="Disabled">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid x:Name="WrapGrid" Orientation="Horizontal" MaximumRowsOrColumns="7"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:DayCellViewModel">
                        <Border Margin="3" Padding="8" CornerRadius="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" BorderThickness="0" Background="{x:Bind IsToday, Mode=OneWay, Converter={StaticResource BoolToTodayBrushConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{x:Bind DayNumber}" HorizontalAlignment="Left" VerticalAlignment="Top" FontWeight="Bold" FontSize="15" Margin="2,0,0,4" Opacity="{x:Bind IsCurrentMonth, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}"/>

                                <ItemsControl Grid.Row="1" ItemsSource="{x:Bind Items}" Margin="0,2,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:AgendaItem">
                                            <Border Background="{x:Bind ColorHex, Converter={StaticResource ProviderToBrushConverter}}" Margin="0,2" Padding="6,4" CornerRadius="4">
                                                <TextBlock Text="{x:Bind Title}"
                                                           Foreground="{x:Bind ColorHex, Converter={StaticResource ProviderToTextBrushConverter}}"
                                                           FontSize="11" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>

        <Grid x:Name="TimelinePane" Grid.Column="2" Background="{ThemeResource LayerFillColorAltBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1,0,0,0" Padding="24,32,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="4,0,0,20">
                <TextBlock x:Uid="CalendarPage_AllAgendas" x:Name="TxtSideBarDate" Text="全部日程" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" Margin="0,0,72,0" VerticalAlignment="Center" Width="32" Height="32" Padding="0"
                        Background="Transparent" BorderThickness="0" Click="ToggleTimelinePane_Click" ToolTipService.ToolTip="折叠日程">
                    <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                </Button>
                <Button x:Uid="CalendarPage_BtnAdd" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource AccentButtonStyle}" Padding="12,4" Click="BtnAddNew_Click">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock x:Uid="Flyout_TextAdd" Text="新建" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>
            <ListView x:Name="SideBarAgendaList" Grid.Row="1" ItemsSource="{x:Bind SelectedDayItems}" SelectionMode="None" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:AgendaItem">
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="65"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind Subtitle}" FontSize="13" FontWeight="Medium" Opacity="0.6" VerticalAlignment="Top" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            <Border Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8" Padding="12,14" Tapped="AgendaCard_Tapped">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="4" CornerRadius="2" Background="{x:Bind ColorHex, Converter={StaticResource ProviderToBrushConverter}}" Margin="0,0,12,0" VerticalAlignment="Stretch"/>

                                    <FontIcon Grid.Column="1" Glyph="&#xE783;" FontSize="14" Foreground="{ThemeResource SystemAccentColor}" Visibility="{x:Bind IsEvent}" VerticalAlignment="Top" Margin="0,3,12,0"/>

                                    <StackPanel Grid.Column="2" Spacing="8">
                                        <TextBlock Text="{x:Bind Title}" Visibility="{x:Bind IsEvent}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" LineHeight="20"/>
                                        <Grid Visibility="{x:Bind IsTask}" Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" Click="TaskCheckBox_Click" Tapped="TaskCheckBox_Tapped" Margin="0,-6,8,0" MinWidth="0"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Title}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" LineHeight="20"
                                               TextDecorations="{x:Bind IsCompleted, Mode=OneWay, Converter={StaticResource BoolToStrikethroughConverter}}"
                                               Opacity="{x:Bind IsCompleted, Mode=OneWay, Converter={StaticResource TaskCompletedOpacityConverter}}"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="6" Visibility="{x:Bind HasLocation, Mode=OneWay}">
                                            <FontIcon Glyph="&#xE707;" FontSize="12" Opacity="0.5" VerticalAlignment="Center"/>
                                            <TextBlock Text="{x:Bind Location, Mode=OneWay}" FontSize="13" Opacity="0.7" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="6" Visibility="{x:Bind HasDescription, Mode=OneWay}">
                                            <FontIcon Glyph="&#xE946;" FontSize="12" Opacity="0.5" VerticalAlignment="Top" Margin="0,3,0,0"/>
                                            <TextBlock Text="{x:Bind Description, Mode=OneWay}" FontSize="13" Opacity="0.7" MaxLines="3" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" LineHeight="18"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <ContentDialog x:Uid="CalendarDialog" x:Name="EditDialog" Title="编辑日程 / 任务" PrimaryButtonText="保存" SecondaryButtonText="删除" CloseButtonText="取消" PrimaryButtonClick="EditDialog_PrimaryButtonClick" SecondaryButtonClick="EditDialog_SecondaryButtonClick">
            <StackPanel Spacing="16" Width="360" Margin="0,12,0,0">
                <ComboBox x:Uid="CalendarDialog_Provider" x:Name="EditCmbProvider" Header="所属账户" HorizontalAlignment="Stretch" />
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <RadioButton x:Uid="CalendarDialog_RadioEvent" x:Name="EditRadioEvent" Content="日程" IsChecked="True" Checked="EditRadioType_Changed"/>
                    <RadioButton x:Uid="CalendarDialog_RadioTask" x:Name="EditRadioTask" Content="任务" Checked="EditRadioType_Changed"/>
                </StackPanel>
                <ComboBox x:Name="EditRecurrenceComboBox" Header="重复" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="不重复" Tag="None"/>
                    <ComboBoxItem Content="每天" Tag="Daily"/>
                    <ComboBoxItem Content="每周" Tag="Weekly"/>
                    <ComboBoxItem Content="每月" Tag="Monthly"/>
                    <ComboBoxItem Content="每年" Tag="Yearly"/>
                </ComboBox>

                <TextBox x:Uid="CalendarDialog_TitleInput" x:Name="EditTxtTitle" Header="名称" PlaceholderText="日程名称"/>
                <TextBox x:Uid="CalendarDialog_LocationInput" x:Name="EditTxtLocation" Header="地点 (选填)" PlaceholderText="添加位置信息"/>
                <TextBox x:Uid="CalendarDialog_DescInput" x:Name="EditTxtDescription" Header="详情备注 (选填)" PlaceholderText="记录详细内容..." AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80" MaxHeight="160"/>
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <DatePicker x:Uid="CalendarDialog_DateInput" x:Name="EditDatePicker" Header="日期" HorizontalAlignment="Stretch"/>
                    <CheckBox x:Name="EditChkAllDay" Grid.Column="1" Content="全天事件" VerticalAlignment="Bottom" Margin="0,0,0,4" Checked="EditChkAllDay_Changed" Unchecked="EditChkAllDay_Changed"/>
                </Grid>
                <StackPanel x:Name="EditTimePanel" Spacing="12">
                    <TimePicker x:Uid="CalendarDialog_StartTimeInput" x:Name="EditStartTimePicker" Header="开始时间" HorizontalAlignment="Stretch"/>
                    <TimePicker x:Name="EditEndTimePicker" Header="结束时间" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>
