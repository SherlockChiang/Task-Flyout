<Page
    x:Class="Task_Flyout.Views.WeatherPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Task_Flyout.Services"
    Background="Transparent">

    <ScrollViewer Padding="40">
        <StackPanel Spacing="28" MaxWidth="800" HorizontalAlignment="Left">
            <TextBlock x:Uid="WeatherPage_Title" Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- Current Weather Summary Card (top) -->
            <Border x:Name="CurrentWeatherCard" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                    BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4" Margin="0,0,28,0" MinWidth="90">
                        <TextBlock x:Name="CurrentIcon" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CurrentTemp" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                        <TextBlock x:Name="CurrentDesc" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CurrentCity" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <StackPanel x:Name="CurrentDetailsPanel" Orientation="Horizontal" Spacing="16" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 24-Hour Forecast -->
            <StackPanel x:Name="ForecastPanel" Spacing="12" Visibility="Collapsed">
                <TextBlock x:Uid="WeatherPage_24Hour" FontWeight="SemiBold" FontSize="16"/>
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="12">
                    <ListView x:Name="HourlyListView" SelectionMode="Single" SelectionChanged="HourlyListView_SelectionChanged"
                              ScrollViewer.HorizontalScrollMode="Enabled" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollMode="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="2"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="2"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:HourlyWeather">
                                <StackPanel Width="56" Spacing="8" HorizontalAlignment="Center" Margin="2,6">
                                    <TextBlock Text="{x:Bind Time}" HorizontalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{x:Bind Icon}" FontSize="24" HorizontalAlignment="Center" FontFamily="{x:Bind IconFont}"/>
                                    <TextBlock Text="{x:Bind Temperature}" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="13"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <!-- Detail Panel for selected hour -->
                <Border x:Name="HourDetailPanel" Visibility="Collapsed"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8"
                        BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Padding="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Center" Spacing="4" Margin="0,0,24,0" MinWidth="80">
                            <TextBlock x:Name="DetailIcon" FontSize="44" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DetailTemp" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DetailTime" FontSize="13" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="DetailDesc" FontSize="13" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>

                        <ItemsRepeater x:Name="DetailFieldsRepeater" Grid.Column="1">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout MinItemWidth="140" MinColumnSpacing="8" MinRowSpacing="6"/>
                            </ItemsRepeater.Layout>
                        </ItemsRepeater>
                    </Grid>
                </Border>
            </StackPanel>

            <ProgressRing x:Name="LoadingRing" IsActive="False" HorizontalAlignment="Left" Margin="0,12,0,0"/>

            <!-- Settings Card (moved to bottom) -->
            <StackPanel Spacing="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="24" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">

                <ToggleSwitch x:Uid="WeatherPage_Toggle" x:Name="WeatherToggle" Toggled="WeatherToggle_Toggled"/>

                <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                <StackPanel Spacing="4">
                    <ToggleSwitch x:Name="WeatherBarToggle" Header="Taskbar Weather Bar" OnContent="On" OffContent="Off" Toggled="WeatherBarToggle_Toggled"/>
                    <TextBlock x:Name="WeatherBarDesc" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap"/>
                </StackPanel>

                <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                <StackPanel Spacing="8">
                    <TextBlock x:Uid="WeatherPage_CityHeader" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Grid ColumnSpacing="12" HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <AutoSuggestBox Grid.Column="0" x:Uid="WeatherPage_CitySearchBox" x:Name="CitySearchBox"
                                        TextChanged="CitySearchBox_TextChanged" QuerySubmitted="CitySearchBox_QuerySubmitted"
                                        SuggestionChosen="CitySearchBox_SuggestionChosen" VerticalAlignment="Center"/>

                        <Button x:Uid="WeatherPage_BtnRefresh" Grid.Column="1" Click="BtnRefresh_Click" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                <!-- Weather Source -->
                <StackPanel Spacing="8">
                    <ComboBox x:Name="SourceComboBox" x:Uid="WeatherPage_SourceHeader" Width="300" HorizontalAlignment="Left" SelectionChanged="SourceComboBox_SelectionChanged">
                        <ComboBoxItem Content="Open-Meteo" Tag="OpenMeteo"/>
                        <ComboBoxItem Content="wttr.in" Tag="WttrIn"/>
                    </ComboBox>
                    <TextBlock x:Name="SourceHintText" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" MaxWidth="400"/>
                </StackPanel>

                <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                <!-- Icon Font -->
                <StackPanel Spacing="8">
                    <ComboBox x:Uid="WeatherPage_IconFontHeader" x:Name="IconFontComboBox" Width="300" HorizontalAlignment="Left" SelectionChanged="IconFontComboBox_SelectionChanged">
                        <ComboBoxItem x:Uid="WeatherPage_FontEmoji" Tag="Segoe UI Emoji"/>
                        <ComboBoxItem x:Uid="WeatherPage_FontSymbol" Tag="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                        <ComboBoxItem x:Uid="WeatherPage_FontCustom" Tag="__custom__"/>
                    </ComboBox>

                    <AutoSuggestBox x:Uid="WeatherPage_CustomFontBox" x:Name="CustomFontBox"
                                    Width="300" HorizontalAlignment="Left" Visibility="Collapsed"
                                    TextChanged="CustomFontBox_TextChanged"
                                    QuerySubmitted="CustomFontBox_QuerySubmitted"
                                    SuggestionChosen="CustomFontBox_SuggestionChosen"/>
                </StackPanel>
            </StackPanel>

            <!-- Flyout Display Fields Card -->
            <StackPanel Spacing="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="24" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <TextBlock x:Name="FlyoutFieldsHeader" FontWeight="SemiBold" FontSize="16"/>
                <TextBlock x:Name="FlyoutFieldsDesc" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                <ItemsRepeater x:Name="FieldToggleRepeater">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="180" MinColumnSpacing="12" MinRowSpacing="4"/>
                    </ItemsRepeater.Layout>
                </ItemsRepeater>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
