<Application
    x:Class="Task_Flyout.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tb="using:H.NotifyIcon"
    xmlns:local="using:Task_Flyout">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <tb:TaskbarIcon x:Key="MyTrayIcon"
                ToolTipText="Task Flyout">
                <tb:TaskbarIcon.ContextFlyout>
                    <MenuFlyout x:Name="TrayMenu">
                        <MenuFlyoutItem x:Uid="TrayMenu_Status" x:Name="MenuStatus" Text="Task Flyout · Ready" IsEnabled="False"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Uid="TrayMenu_NewItem" x:Name="MenuNewItem" Text="New item"/>
                        <MenuFlyoutItem x:Uid="TrayMenu_SyncNow" x:Name="MenuSyncNow" Text="Sync now"/>
                        <MenuFlyoutItem x:Uid="TrayMenu_Compose" x:Name="MenuCompose" Text="Compose mail"/>
                        <MenuFlyoutItem x:Uid="TrayMenu_Weather" x:Name="MenuWeather" Text="Weather"/>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Uid="TrayMenu_ShowMain" x:Name="MenuShowMain" Text="显示主页面">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Setting"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Uid="TrayMenu_Exit" x:Name="MenuExit" Text="退出">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Cancel"/>
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </tb:TaskbarIcon.ContextFlyout>
            </tb:TaskbarIcon>
        </ResourceDictionary>
    </Application.Resources>
</Application>
