<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Task_Flyout.FlyoutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Task_Flyout"
    xmlns:models="using:Task_Flyout.Models">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource LayerFillColorDefaultBrush}" UseLayoutRounding="True">
        <Grid.Resources>
            <local:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
            <local:BoolToStrikethroughConverter x:Key="BoolToStrikethroughConverter"/>
            <local:ColorHexToBrushConverter x:Key="ColorHexToBrushConverter"/>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition x:Name="ContentRow" Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="16,0,16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Uid="Flyout_BtnGoToToday" Grid.Column="0" Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Left" Padding="0" Click="BtnGoToToday_Click" ToolTipService.ToolTip="回到今天">
                    <StackPanel>
                        <TextBlock x:Name="TxtRealTimeClock" Text="10:30" FontSize="32" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="TxtRealTimeDate" Text="2023年10月24日 星期二" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Button>

                <Button x:Uid="Flyout_BtnWeather" x:Name="WeatherPanel" Grid.Column="1" Background="Transparent" BorderThickness="0"
                        Padding="4" VerticalAlignment="Center" Visibility="Collapsed"
                        Click="BtnWeather_Click" ToolTipService.ToolTip="查看天气详情">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock x:Name="WeatherIcon" Text="☀️" FontSize="22"
                                   FontFamily="Segoe UI Emoji" VerticalAlignment="Center" Margin="0,0,4,0"/>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtWeatherTemp" Text="--" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock x:Name="TxtWeatherDesc" Text="" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" MaxWidth="60" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </Grid>

            <Grid Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,12" Width="320" Height="354">
                <CalendarView x:Name="MainCalendar" 
                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              CalendarViewDayItemChanging="MainCalendar_CalendarViewDayItemChanging" 
                              SelectedDatesChanged="MainCalendar_SelectedDatesChanged">
                    <CalendarView.CalendarViewDayItemStyle>
                        <Style TargetType="CalendarViewDayItem">
                            <Setter Property="Margin" Value="1"/>
                        </Style>
                    </CalendarView.CalendarViewDayItemStyle>
                </CalendarView>

                <Canvas x:Name="DotOverlay" IsHitTestVisible="False" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            </Grid>

        </Grid>

        <Grid x:Name="AgendaContainer" Grid.Row="1" Margin="16,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="4,0,0,8" Orientation="Horizontal" Spacing="8" Background="Transparent" CornerRadius="4">
                <TextBlock x:Name="TxtSelectedDateHeader" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                <TextBlock x:Name="TxtRelativeDate" FontSize="13" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" Visibility="Collapsed"/>
            </StackPanel>

            <Border Grid.Row="1" Background="{ThemeResource ControlFillColorDefaultBrush}"
                    CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <ListView x:Name="AgendaListControl" SelectionMode="None" Padding="0,8" 
                          IsItemClickEnabled="True" ItemClick="AgendaListControl_ItemClick"
                          ScrollViewer.VerticalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollMode="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:AgendaItem">
                            <Grid Margin="12,6" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Width="24" Margin="0,0,12,0">
                                    <Border Width="4" HorizontalAlignment="Left"
                                            Background="{Binding ColorHex, Converter={StaticResource ColorHexToBrushConverter}}"
                                            CornerRadius="2" Visibility="{x:Bind IsEvent, Mode=OneWay}"/>
                                    <CheckBox IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" MinWidth="0" Padding="0"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"
                                              Visibility="{x:Bind IsTask, Mode=OneWay}" Click="TaskCheckBox_Click"/>
                                </Grid>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="{x:Bind Title, Mode=OneWay}" FontWeight="SemiBold" FontSize="14"
                                               TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind Title, Mode=OneWay}"
                                               TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToStrikethroughConverter}}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{x:Bind HasLocation, Mode=OneWay}" Margin="0,2,0,0">
                                        <FontIcon Glyph="&#xE707;" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind Location, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="2" Background="{ThemeResource LayerFillColorAltBrush}"
                                        CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Subtitle, Mode=OneWay}" FontSize="12" FontWeight="Medium"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="16,16,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Uid="Flyout_BtnSettings" Grid.Column="0" Click="BtnSettings_Click" ToolTipService.ToolTip="设置" Background="Transparent" BorderThickness="0" Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                <SymbolIcon Symbol="Setting"/>
            </Button>
            <Button x:Uid="Flyout_BtnRefresh" Grid.Column="1" Click="BtnRefresh_Click" ToolTipService.ToolTip="强制同步云端" Background="Transparent" BorderThickness="0" Margin="4,0,0,0" Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                <SymbolIcon Symbol="Refresh"/>
            </Button>
            <Button x:Uid="Flyout_BtnPin" x:Name="BtnPin" Grid.Column="2" Click="BtnPin_Click" ToolTipService.ToolTip="置顶窗口" Background="Transparent" BorderThickness="0" Margin="4,0,0,0" Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                <FontIcon x:Name="PinIcon" Glyph="&#xE77A;" FontSize="16"/>
            </Button>
            <Button Grid.Column="4" Style="{StaticResource AccentButtonStyle}" Padding="12,4" Click="BtnToggleAddPanel_Click">
                <StackPanel Orientation="Horizontal">
                    <SymbolIcon Symbol="Add" Margin="0,0,8,0"/>
                    <TextBlock x:Uid="Flyout_TextAdd" Text="添加"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border x:Name="AddPanel" Grid.Row="1" Background="{ThemeResource ControlFillColorDefaultBrush}"
                CornerRadius="8" Margin="16,0,16,0" Padding="16" Visibility="Collapsed"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">

            <ScrollViewer x:Name="AddPanelScrollViewer" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Disabled">
                <StackPanel Spacing="10" Padding="0,0,0,12">
                    <ComboBox x:Uid="Flyout_CmbProvider" x:Name="CmbAddProvider" Header="所属账户" HorizontalAlignment="Stretch" />

                    <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,-4,0,0">
                        <RadioButton x:Uid="Flyout_RadioEvent" x:Name="RadioTypeEvent" Content="日程" IsChecked="True" Checked="RadioType_Changed"/>
                        <RadioButton x:Uid="Flyout_RadioTask" x:Name="RadioTypeTask" Content="任务" Checked="RadioType_Changed"/>
                    </StackPanel>

                    <TextBox x:Uid="Flyout_TxtNewTitle" x:Name="TxtNewTitle" PlaceholderText="输入标题内容..." />
                    <TextBox x:Uid="Flyout_TxtLocation" x:Name="TxtLocation" PlaceholderText="添加地点（选填）" />

                    <StackPanel Spacing="8">
                        <CheckBox x:Uid="Flyout_ChkAllDay" x:Name="ChkAllDay" Content="全天" IsChecked="False" Checked="ChkAllDay_Checked" Unchecked="ChkAllDay_Unchecked" Margin="0,0,0,-4"/>

                        <StackPanel x:Name="TimePanel" Spacing="8">
                            <TimePicker x:Uid="Flyout_TimePickerStart" x:Name="TimePickerStart" Header="开始时间" ClockIdentifier="24HourClock" HorizontalAlignment="Stretch" MinuteIncrement="5"/>
                            <TimePicker x:Uid="Flyout_TimePickerEnd" x:Name="TimePickerEnd" Header="结束时间" ClockIdentifier="24HourClock" HorizontalAlignment="Stretch" MinuteIncrement="5"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
                        <Button x:Uid="Flyout_BtnCancel" Content="取消" Click="BtnCancelAdd_Click"/>
                        <Button x:Uid="Flyout_BtnSave" Content="保存" Width="80" Style="{StaticResource AccentButtonStyle}" Click="BtnSaveNewItem_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>