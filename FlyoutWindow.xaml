<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Task_Flyout.FlyoutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Task_Flyout"
    xmlns:models="using:Task_Flyout.Models">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource LayerFillColorDefaultBrush}" UseLayoutRounding="True">
        <Grid.Resources>
            <local:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
            <local:BoolToStrikethroughConverter x:Key="BoolToStrikethroughConverter"/>

            <CornerRadius x:Key="CalendarViewDayItemCornerRadius">8</CornerRadius>
            <CornerRadius x:Key="CalendarViewDayItemTodayBackgroundCornerRadius">8</CornerRadius>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Margin="16,0,16,12" Background="Transparent" BorderThickness="0" 
                    HorizontalAlignment="Left" Padding="0" Click="BtnGoToToday_Click" ToolTipService.ToolTip="回到今天">
                <StackPanel>
                    <TextBlock x:Name="TxtRealTimeClock" Text="10:30" FontSize="32" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock x:Name="TxtRealTimeDate" Text="2023年10月24日 星期二" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Button>

            <CalendarView x:Name="MainCalendar" 
                          Grid.Row="1"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,12"
                          Width="320" Height="340"
                          CalendarViewDayItemChanging="MainCalendar_CalendarViewDayItemChanging"
                          SelectedDatesChanged="MainCalendar_SelectedDatesChanged">
                <CalendarView.CalendarViewDayItemStyle>
                    <Style TargetType="CalendarViewDayItem">
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="Margin" Value="1"/>
                    </Style>
                </CalendarView.CalendarViewDayItemStyle>
            </CalendarView>
        </Grid>

        <Grid Grid.Row="1" Margin="16,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="TxtSelectedDateHeader" Grid.Row="0" Text="2023年10月24日" 
                       FontSize="14" FontWeight="SemiBold" Margin="4,0,0,8"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Border Grid.Row="1" Background="{ThemeResource ControlFillColorDefaultBrush}" 
                    CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <ListView x:Name="AgendaListControl" SelectionMode="None" Padding="0,8"
                          ScrollViewer.VerticalScrollBarVisibility="Hidden"
                          ScrollViewer.VerticalScrollMode="Enabled">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:AgendaItem">
                            <Grid Margin="12,6" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="4" Background="{ThemeResource SystemAccentColor}" 
                                        CornerRadius="2" Margin="0,0,12,0" 
                                        Visibility="{x:Bind IsEvent, Mode=OneWay}"/>
                                <CheckBox Grid.Column="0" IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" 
                                          MinWidth="0" Padding="0" Margin="0,0,12,0" 
                                          VerticalAlignment="Center" HorizontalAlignment="Left"
                                          Visibility="{x:Bind IsTask, Mode=OneWay}" Click="TaskCheckBox_Click"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="{x:Bind Title, Mode=OneWay}" FontWeight="SemiBold" FontSize="14" 
                                               TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{x:Bind Title, Mode=OneWay}"
                                               TextDecorations="{Binding IsCompleted, Converter={StaticResource BoolToStrikethroughConverter}}"/>
                                    <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{x:Bind HasLocation, Mode=OneWay}" Margin="0,2,0,0">
                                        <FontIcon Glyph="&#xE710;" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="{x:Bind Location, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="2" Background="{ThemeResource LayerFillColorAltBrush}" 
                                        CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Subtitle, Mode=OneWay}" FontSize="12" FontWeight="Medium" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="16,16,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" ToolTipService.ToolTip="设置" Background="Transparent" BorderThickness="0" Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                <SymbolIcon Symbol="Setting"/>
            </Button>
            <Button Grid.Column="1" Click="BtnRefresh_Click" ToolTipService.ToolTip="强制同步云端" Background="Transparent" BorderThickness="0" Margin="4,0,0,0" Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                <SymbolIcon Symbol="Refresh"/>
            </Button>
            <Button Grid.Column="3" Style="{StaticResource AccentButtonStyle}" Padding="12,4">
                <Button.Flyout>
                    <Flyout x:Name="AddTaskFlyout">
                        <StackPanel Width="240" Spacing="16">
                            <TextBlock Text="新建日程或任务" FontWeight="SemiBold" FontSize="16"/>
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <RadioButton x:Name="RadioTypeTask" Content="任务" IsChecked="True"/>
                                <RadioButton x:Name="RadioTypeEvent" Content="日程"/>
                            </StackPanel>
                            <TextBox x:Name="TxtNewTitle" PlaceholderText="输入名称..." />
                            <StackPanel Spacing="8">
                                <CheckBox x:Name="ChkAllDay" Content="全天" IsChecked="False" 
                                          Checked="ChkAllDay_Checked" Unchecked="ChkAllDay_Unchecked"/>
                                <TimePicker x:Name="TimePickerNew" Header="时间" ClockIdentifier="24HourClock" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <Button Content="保存" HorizontalAlignment="Right" Width="80"
                                    Style="{StaticResource AccentButtonStyle}" 
                                    Click="BtnSaveNewItem_Click"/>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
                <StackPanel Orientation="Horizontal">
                    <SymbolIcon Symbol="Add" Margin="0,0,8,0"/>
                    <TextBlock Text="添加任务"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>