<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Task_Flyout.WeatherBarWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Border x:Name="MainBorder"
                CornerRadius="6"
                Background="Transparent"
                BorderThickness="0"
                PointerEntered="MainBorder_PointerEntered"
                PointerExited="MainBorder_PointerExited">

            <Border x:Name="TopBorder"
                    CornerRadius="5"
                    BorderThickness="0,1.25,0,0"
                    BorderBrush="Transparent"
                    Margin="0,0,0,1.25">

                <Grid x:Name="MainGrid"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      RenderTransformOrigin="0,0.5">
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                    </Grid.RenderTransform>

                    <Button x:Name="WeatherButton"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Click="WeatherButton_Click">
                        <StackPanel x:Name="ContentPanel" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="4,0,-100,0">
                            <Grid Width="24" Height="24" VerticalAlignment="Center">
                                <TextBlock x:Name="WeatherIcon" Text="--" FontSize="20"
                                           FontFamily="Segoe UI Emoji" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <Image x:Name="WeatherIconImage" Visibility="Collapsed" Stretch="Uniform"/>
                                <Image x:Name="WeatherIconImage1" Visibility="Collapsed" Stretch="Uniform"/>
                                <Image x:Name="WeatherIconImage2" Visibility="Collapsed" Stretch="Uniform"/>
                                <Image x:Name="WeatherIconImage3" Visibility="Collapsed" Stretch="Uniform"/>
                            </Grid>
                            <TextBlock x:Name="TxtTemp" Text="--" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtDesc" Text="" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtFeels" Text="" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" Visibility="Collapsed"/>
                            <TextBlock x:Name="TxtHumidity" Text="" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" Visibility="Collapsed"/>
                            <TextBlock x:Name="TxtWind" Text="" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" Visibility="Collapsed"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
