<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Task_Flyout.WeatherBarWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Background="{ThemeResource LayerFillColorDefaultBrush}"
          CornerRadius="6" Padding="12,0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">

        <Button x:Name="WeatherButton" Background="Transparent" BorderThickness="0"
                Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                Click="WeatherButton_Click">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock x:Name="WeatherIcon" Text="--" FontSize="20"
                           FontFamily="Segoe UI Emoji" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtTemp" Text="--" FontSize="15" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtDesc" Text="" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" MaxWidth="72" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Button>
    </Grid>
</Window>
